<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CastorApplication.ViewModels"
        x:Class="CastorApplication.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Castor Studio"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource AppFg1}"
        MinWidth="1024" MinHeight="600"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Icon="/Assets/castor.png">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg3}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppNavHoverBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg1}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="48,*">

        <!-- ═══ NAVBAR ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="220,*,220">

                <!-- Logo -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Margin="16,0">
                    <Image Height="26" Width="26"
                           Source="avares://CastorApplication/Assets/castor.png"/>
                    <TextBlock Text="CASTOR"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppFg1}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation tabs -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <!-- STUDIO -->
                    <StackPanel Orientation="Vertical">
                        <Button Classes="nav" Content="STUDIO"
                                Command="{Binding ShowStudioCommand}"/>
                        <Border Height="2" CornerRadius="1"
                                Background="#5b8def"
                                IsVisible="{Binding IsStudioActive}"
                                Margin="8,0"/>
                    </StackPanel>

                    <!-- MULTICAM -->
                    <StackPanel Orientation="Vertical">
                        <Button Classes="nav" Content="MULTICAM"
                                Command="{Binding ShowMulticamCommand}"/>
                        <Border Height="2" CornerRadius="1"
                                Background="#5b8def"
                                IsVisible="{Binding IsMulticamActive}"
                                Margin="8,0"/>
                    </StackPanel>

                    <!-- SCENES -->
                    <StackPanel Orientation="Vertical">
                        <Button Classes="nav" Content="SCÈNES"
                                Command="{Binding ShowScenesCommand}"/>
                        <Border Height="2" CornerRadius="1"
                                Background="#5b8def"
                                IsVisible="{Binding IsScenesActive}"
                                Margin="8,0"/>
                    </StackPanel>

                    <!-- PARAMETRES -->
                    <StackPanel Orientation="Vertical">
                        <Button Classes="nav" Content="PARAMÈTRES"
                                Command="{Binding ShowSettingsCommand}"/>
                        <Border Height="2" CornerRadius="1"
                                Background="#5b8def"
                                IsVisible="{Binding IsSettingsActive}"
                                Margin="8,0"/>
                    </StackPanel>

                </StackPanel>

                <!-- Status + Account -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Margin="16,0">

                    <!-- Status badge -->
                    <Border Background="{DynamicResource AppSurface3}"
                            BorderBrush="{DynamicResource AppBorder}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10,5">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="7" Height="7" Fill="{DynamicResource AppFg5}" VerticalAlignment="Center"/>
                            <TextBlock Text="OFFLINE"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppFg5}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Account button with login Flyout -->
                    <Button Background="{DynamicResource AppNavBadgeBg}"
                            BorderBrush="{DynamicResource AppBorder2}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Width="32" Height="32"
                            Padding="0"
                            Cursor="Hand">
                        <TextBlock Text="U"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="#5b8def"/>
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Width="280" Spacing="14" Margin="4">
                                    <TextBlock Text="CONNEXION"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AppFg1}"/>
                                    <Rectangle Height="1" Fill="{DynamicResource AppBorder2}"/>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Email"
                                                   Foreground="{DynamicResource AppFg3}"
                                                   FontSize="11"/>
                                        <TextBox Watermark="votre@email.com"
                                                 Background="{DynamicResource AppSurface2}"
                                                 BorderBrush="{DynamicResource AppBorder2}"
                                                 Foreground="{DynamicResource AppFg2}"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Mot de passe"
                                                   Foreground="{DynamicResource AppFg3}"
                                                   FontSize="11"/>
                                        <TextBox PasswordChar="•"
                                                 Watermark="Mot de passe"
                                                 Background="{DynamicResource AppSurface2}"
                                                 BorderBrush="{DynamicResource AppBorder2}"
                                                 Foreground="{DynamicResource AppFg2}"/>
                                    </StackPanel>

                                    <Button Content="SE CONNECTER"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Height="36"
                                            Background="#5b8def"
                                            Foreground="#eaeaf0"
                                            BorderThickness="0"
                                            CornerRadius="6"
                                            FontSize="12"
                                            FontWeight="Bold"
                                            Cursor="Hand"/>

                                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                                        <TextBlock Text="Pas encore de compte ?"
                                                   Foreground="{DynamicResource AppFg4}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Inscrivez-vous sur castor-studio.app"
                                                   Foreground="#5b8def"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   Cursor="Hand"/>
                                    </StackPanel>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>

        <!-- Page content -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentPage}"/>

    </Grid>
</Window>
