<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels"
             x:Class="CastorApplication.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <UserControl.Styles>

        <Style Selector="Button.settings-nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg3}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.settings-nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppNavHoverBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg2}"/>
        </Style>

        <Style Selector="TextBlock.setting-label">
            <Setter Property="Foreground" Value="{DynamicResource AppFg3}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg4}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style Selector="Button.platform-connect">
            <Setter Property="Background" Value="{DynamicResource AppAccentBg}"/>
            <Setter Property="Foreground" Value="#5b8def"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.platform-connect:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppAccentBg2}"/>
        </Style>

    </UserControl.Styles>

    <Grid ColumnDefinitions="200, 1, *" Background="{DynamicResource AppBg}">

        <!-- ═══ SIDEBAR ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource AppSurface}">
            <Grid RowDefinitions="56, 1, *">

                <TextBlock Grid.Row="0"
                           Text="PARAMÈTRES"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AppFg4}"
                           VerticalAlignment="Center"
                           Margin="18,0"/>

                <Rectangle Grid.Row="1" Fill="{DynamicResource AppBorder}"/>

                <StackPanel Grid.Row="2" Margin="0,8">

                    <!-- Général -->
                    <Border IsVisible="{Binding IsGeneralActive}"
                            Background="{DynamicResource AppAccentBg2}" BorderBrush="#5b8def" BorderThickness="3,0,0,0">
                        <TextBlock Text="Général" Foreground="{DynamicResource AppFg1}" FontSize="13"
                                   FontWeight="SemiBold" Margin="15,10"/>
                    </Border>
                    <Button IsVisible="{Binding !IsGeneralActive}"
                            Classes="settings-nav" Content="Général"
                            Command="{Binding ShowGeneralCommand}"/>

                    <!-- Vidéo -->
                    <Border IsVisible="{Binding IsVideoActive}"
                            Background="{DynamicResource AppAccentBg2}" BorderBrush="#5b8def" BorderThickness="3,0,0,0">
                        <TextBlock Text="Vidéo" Foreground="{DynamicResource AppFg1}" FontSize="13"
                                   FontWeight="SemiBold" Margin="15,10"/>
                    </Border>
                    <Button IsVisible="{Binding !IsVideoActive}"
                            Classes="settings-nav" Content="Vidéo"
                            Command="{Binding ShowVideoCommand}"/>

                    <!-- Audio -->
                    <Border IsVisible="{Binding IsAudioActive}"
                            Background="{DynamicResource AppAccentBg2}" BorderBrush="#5b8def" BorderThickness="3,0,0,0">
                        <TextBlock Text="Audio" Foreground="{DynamicResource AppFg1}" FontSize="13"
                                   FontWeight="SemiBold" Margin="15,10"/>
                    </Border>
                    <Button IsVisible="{Binding !IsAudioActive}"
                            Classes="settings-nav" Content="Audio"
                            Command="{Binding ShowAudioCommand}"/>

                    <!-- Streaming -->
                    <Border IsVisible="{Binding IsStreamingActive}"
                            Background="{DynamicResource AppAccentBg2}" BorderBrush="#5b8def" BorderThickness="3,0,0,0">
                        <TextBlock Text="Streaming" Foreground="{DynamicResource AppFg1}" FontSize="13"
                                   FontWeight="SemiBold" Margin="15,10"/>
                    </Border>
                    <Button IsVisible="{Binding !IsStreamingActive}"
                            Classes="settings-nav" Content="Streaming"
                            Command="{Binding ShowStreamingCommand}"/>

                    <!-- Sortie -->
                    <Border IsVisible="{Binding IsOutputActive}"
                            Background="{DynamicResource AppAccentBg2}" BorderBrush="#5b8def" BorderThickness="3,0,0,0">
                        <TextBlock Text="Sortie" Foreground="{DynamicResource AppFg1}" FontSize="13"
                                   FontWeight="SemiBold" Margin="15,10"/>
                    </Border>
                    <Button IsVisible="{Binding !IsOutputActive}"
                            Classes="settings-nav" Content="Sortie"
                            Command="{Binding ShowOutputCommand}"/>

                    <!-- Comptes -->
                    <Border IsVisible="{Binding IsAccountsActive}"
                            Background="{DynamicResource AppAccentBg2}" BorderBrush="#5b8def" BorderThickness="3,0,0,0">
                        <TextBlock Text="Comptes" Foreground="{DynamicResource AppFg1}" FontSize="13"
                                   FontWeight="SemiBold" Margin="15,10"/>
                    </Border>
                    <Button IsVisible="{Binding !IsAccountsActive}"
                            Classes="settings-nav" Content="Comptes"
                            Command="{Binding ShowAccountsCommand}"/>

                </StackPanel>
            </Grid>
        </Border>

        <Rectangle Grid.Column="1" Fill="{DynamicResource AppBorder}"/>

        <!-- ═══ SETTINGS CONTENT ═══ -->
        <Grid Grid.Column="2" RowDefinitions="*,Auto">
            <ScrollViewer Grid.Row="0">
                <StackPanel Margin="28,20" Spacing="28">

                <!-- ══ GÉNÉRAL ══ -->
                <StackPanel IsVisible="{Binding IsGeneralActive}" Spacing="14">
                    <TextBlock Text="GÉNÉRAL" Classes="section-title"/>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Langue" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding General.SelectedLanguageIndex}">
                            <ComboBoxItem Content="Français"/>
                            <ComboBoxItem Content="English"/>
                            <ComboBoxItem Content="Español"/>
                        </ComboBox>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Démarrage automatique" Classes="setting-label"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding General.AutoStart}"/>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Thème" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding General.SelectedThemeIndex}">
                            <ComboBoxItem Content="Sombre"/>
                            <ComboBoxItem Content="Clair"/>
                        </ComboBox>
                    </Grid>

                    <Rectangle Height="1" Fill="{DynamicResource AppBorder}" Margin="0,4"/>

                    <!-- About / Website -->
                    <Border Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="16,14">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Castor Studio" Foreground="{DynamicResource AppFg1}"
                                           FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Libérez le flot de vos événements"
                                           Foreground="{DynamicResource AppFg4}" FontSize="11" FontStyle="Italic"/>
                                <TextBlock Text="castor-studio.app"
                                           Foreground="#5b8def" FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                <Button Content="Documentation"
                                        Background="{DynamicResource AppAccentBg}" Foreground="#5b8def"
                                        BorderThickness="0" Padding="12,6" CornerRadius="5"
                                    FontSize="11" FontWeight="SemiBold"
                                        HorizontalContentAlignment="Center" MinWidth="120"/>
                                <Button Content="Support"
                                        Background="{DynamicResource AppSurface2}" Foreground="{DynamicResource AppFg3}"
                                        BorderThickness="1" BorderBrush="{DynamicResource AppBorder2}"
                                        Padding="12,6" CornerRadius="5"
                                    FontSize="11" FontWeight="SemiBold"
                                        HorizontalContentAlignment="Center" MinWidth="120"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ══ VIDÉO ══ -->
                <StackPanel IsVisible="{Binding IsVideoActive}" Spacing="14">
                    <TextBlock Text="VIDÉO" Classes="section-title"/>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Résolution de base" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding Video.SelectedBaseResolutionIndex}">
                            <ComboBoxItem Content="3840 × 2160 (4K)"/>
                            <ComboBoxItem Content="1920 × 1080 (Full HD)"/>
                            <ComboBoxItem Content="1280 × 720 (HD)"/>
                        </ComboBox>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Résolution de sortie" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding Video.SelectedOutputResolutionIndex}">
                            <ComboBoxItem Content="1920 × 1080 (Full HD)"/>
                            <ComboBoxItem Content="1280 × 720 (HD)"/>
                            <ComboBoxItem Content="854 × 480 (SD)"/>
                        </ComboBox>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Images par seconde" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding Video.SelectedFpsIndex}">
                            <ComboBoxItem Content="60 fps"/>
                            <ComboBoxItem Content="30 fps"/>
                            <ComboBoxItem Content="25 fps"/>
                        </ComboBox>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Débit vidéo (kbps)" Classes="setting-label"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" MaxWidth="320">
                            <Slider Minimum="1000" Maximum="20000"
                                    Value="{Binding Video.VideoBitrate}"
                                    Width="220" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Video.VideoBitrateDisplay}"
                                       Foreground="{DynamicResource AppFg4}" FontSize="12"
                                       VerticalAlignment="Center" Width="50"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- ══ AUDIO ══ -->
                <StackPanel IsVisible="{Binding IsAudioActive}" Spacing="14">
                    <TextBlock Text="AUDIO" Classes="section-title"/>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Fréquence d'échantillonnage" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding Audio.SelectedSampleRateIndex}">
                            <ComboBoxItem Content="48 kHz"/>
                            <ComboBoxItem Content="44.1 kHz"/>
                        </ComboBox>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Canaux" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding Audio.SelectedChannelsIndex}">
                            <ComboBoxItem Content="Stéréo"/>
                            <ComboBoxItem Content="Mono"/>
                            <ComboBoxItem Content="5.1 Surround"/>
                        </ComboBox>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Débit audio (kbps)" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding Audio.SelectedAudioBitrateIndex}">
                            <ComboBoxItem Content="320 kbps"/>
                            <ComboBoxItem Content="192 kbps"/>
                            <ComboBoxItem Content="128 kbps"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- ══ STREAMING ══ -->
                <StackPanel IsVisible="{Binding IsStreamingActive}" Spacing="14">
                    <TextBlock Text="STREAMING" Classes="section-title"/>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Plateforme" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding Streaming.SelectedPlatformIndex}">
                            <ComboBoxItem Content="Twitch"/>
                            <ComboBoxItem Content="YouTube Live"/>
                            <ComboBoxItem Content="Facebook Live"/>
                            <ComboBoxItem Content="Personnalisé (RTMP)"/>
                        </ComboBox>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Clé de stream" Classes="setting-label"/>
                        <TextBox Grid.Column="1"
                                 PasswordChar="•"
                                 Text="{Binding Streaming.StreamKey}"
                                 Watermark="Entrez votre clé de stream..."
                                 MaxWidth="320" HorizontalAlignment="Left"
                                 Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}" Foreground="{DynamicResource AppFg2}"/>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="URL RTMP" Classes="setting-label"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding Streaming.RtmpUrl}"
                                 Watermark="rtmp://live.twitch.tv/app"
                                 MaxWidth="320" HorizontalAlignment="Left"
                                 Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}" Foreground="{DynamicResource AppFg2}"/>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Serveur" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding Streaming.SelectedServerIndex}">
                            <ComboBoxItem Content="Auto (recommandé)"/>
                            <ComboBoxItem Content="Europe - Paris"/>
                            <ComboBoxItem Content="Europe - Amsterdam"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <!-- ══ SORTIE ══ -->
                <StackPanel IsVisible="{Binding IsOutputActive}" Spacing="14">
                    <TextBlock Text="SORTIE" Classes="section-title"/>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Format d'enregistrement" Classes="setting-label"/>
                        <ComboBox Grid.Column="1" MaxWidth="260" HorizontalAlignment="Left"
                                  SelectedIndex="{Binding Output.SelectedOutputFormatIndex}">
                            <ComboBoxItem Content="MP4 (H.264 + AAC)"/>
                            <ComboBoxItem Content="MKV (H.264 + AAC)"/>
                            <ComboBoxItem Content="WebM (VP9 + Opus)"/>
                        </ComboBox>
                    </Grid>

                    <Grid ColumnDefinitions="180, *">
                        <TextBlock Grid.Column="0" Text="Dossier de sortie" Classes="setting-label"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding Output.OutputPath}"
                                 Watermark="C:\Users\...\Videos"
                                 MaxWidth="320" HorizontalAlignment="Left"
                                 Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}" Foreground="{DynamicResource AppFg2}"/>
                    </Grid>
                </StackPanel>

                <!-- ══ COMPTES ══ -->
                <StackPanel IsVisible="{Binding IsAccountsActive}" Spacing="14">
                    <TextBlock Text="COMPTES ET PLATEFORMES" Classes="section-title"/>

                    <TextBlock Text="Connectez vos comptes de streaming pour diffuser directement depuis Castor."
                               Foreground="{DynamicResource AppFg4}" FontSize="12" Margin="0,0,0,4"/>

                    <!-- Twitch -->
                    <Border Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="14">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                <Border CornerRadius="6" Width="36" Height="36" ClipToBounds="True">
                                    <Image Source="avares://CastorApplication/Assets/twitch-logo.png"
                                           Width="36" Height="36"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Twitch" Foreground="{DynamicResource AppFg1}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Accounts.TwitchStatus}" Foreground="{DynamicResource AppFg4}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Accounts.TwitchButtonText}"
                                    Classes="platform-connect"
                                    Command="{Binding Accounts.ToggleTwitchCommand}"/>
                        </Grid>
                    </Border>

                    <!-- YouTube -->
                    <Border Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="14">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                <Border CornerRadius="6" Width="36" Height="36" ClipToBounds="True">
                                    <Image Source="avares://CastorApplication/Assets/youtube-logo.png"
                                           Width="36" Height="36"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="YouTube Live" Foreground="{DynamicResource AppFg1}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Accounts.YoutubeStatus}" Foreground="{DynamicResource AppFg4}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Accounts.YoutubeButtonText}"
                                    Classes="platform-connect"
                                    Command="{Binding Accounts.ToggleYoutubeCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Facebook -->
                    <Border Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                            CornerRadius="8" Padding="14">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                <Border CornerRadius="6" Width="36" Height="36" ClipToBounds="True">
                                    <Image Source="avares://CastorApplication/Assets/facebook-logo.png"
                                           Width="36" Height="36"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Facebook Live" Foreground="{DynamicResource AppFg1}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Accounts.FacebookStatus}" Foreground="{DynamicResource AppFg4}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                                <Button Grid.Column="2" Content="{Binding Accounts.FacebookButtonText}"
                                    Classes="platform-connect"
                                    Command="{Binding Accounts.ToggleFacebookCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Account hint -->
                    <Border Background="{DynamicResource AppSurface3}" CornerRadius="6" Padding="12,10">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Gérez votre abonnement et vos préférences sur"
                                       Foreground="{DynamicResource AppFg4}" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="castor-studio.app"
                                       Foreground="#5b8def" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                    <Rectangle Height="20" Fill="Transparent"/>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="1"
                    Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="0,1,0,0"
                    Padding="24,12">
                <Button Content="Enregistrer"
                        Classes="platform-connect"
                        Command="{Binding SaveSettingsCommand}"
                        HorizontalAlignment="Right"
                        MinWidth="130"/>
            </Border>
        </Grid>

    </Grid>

</UserControl>
