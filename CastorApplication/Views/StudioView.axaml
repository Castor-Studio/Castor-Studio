<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels"
             xmlns:m="using:CastorApplication.Models"
             xmlns:dock="using:Dock.Avalonia.Controls"
             x:Class="CastorApplication.Views.StudioView"
             x:DataType="vm:StudioViewModel">

    <UserControl.Styles>

        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5c5c72"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="Button.ctrl-btn">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.flyout-start">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="*, 38, 150">

        <!-- ═══ DOCKABLE AREA (Preview vidéo plein écran) ═══ -->
        <dock:DockControl Grid.Row="0" Layout="{Binding Layout}" Margin="4"/>

        <!-- ═══ SCENE SELECTOR BAR ═══ -->
        <Border Grid.Row="1"
                Background="#13131c" CornerRadius="6" Margin="8,0,8,4"
                Padding="12,0" BorderBrush="#2a2a38" BorderThickness="1">
            <Grid ColumnDefinitions="Auto, Auto, *, Auto">
                <TextBlock Grid.Column="0" Text="SCÈNE ACTIVE :"
                           Foreground="#5c5c72" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding SceneNames}"
                          SelectedIndex="{Binding SelectedSceneIndex}"
                          MinWidth="180" VerticalAlignment="Center"
                          Background="#1c1c28" BorderBrush="#36364a"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#34d399" VerticalAlignment="Center"/>
                    <TextBlock Text="Prêt" Foreground="#34d399" FontSize="11"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ BARRE DU BAS (Sources + Mixer Audio + Contrôles) ═══ -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*, 8, *, 8, 220"
              Margin="8,0,8,8">

            <!-- ── SOURCES ── -->
            <Border Grid.Column="0" Background="#13131c" CornerRadius="8" Padding="10,8">
                <Grid RowDefinitions="Auto, *, Auto">

                    <TextBlock Grid.Row="0" Text="SOURCES" Classes="section-header"/>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Sources}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="4,3"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="m:SourceItem">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    <Ellipse Grid.Column="0" Width="7" Height="7"
                                             Fill="{Binding ColorBrush}"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               Foreground="#ccccd8" FontSize="11"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Type}"
                                               Foreground="#5c5c72" FontSize="10"
                                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="2"
                            Content="+ Ajouter source"
                            Command="{Binding AddSourceCommand}"
                            Height="26" FontSize="10"
                            Background="#1c1c28" Foreground="#8888a0"
                            BorderBrush="#36364a" BorderThickness="1"
                            CornerRadius="4" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Margin="0,4,0,0" Cursor="Hand"/>
                </Grid>
            </Border>

            <Rectangle Grid.Column="1" Fill="Transparent"/>

            <!-- ── MIXER AUDIO ── -->
            <Border Grid.Column="2" Background="#13131c" CornerRadius="8" Padding="10,8">
                <StackPanel>
                    <TextBlock Text="MIXER AUDIO" Classes="section-header"/>

                    <!-- Bureau -->
                    <Grid ColumnDefinitions="52, *, 36" Margin="0,0,0,5">
                        <TextBlock Grid.Column="0" Text="Bureau"
                                   Foreground="#8888a0" FontSize="10"
                                   VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                Value="{Binding DesktopVolume}"
                                VerticalAlignment="Center" Margin="4,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding DesktopVolumeDisplay}"
                                   Foreground="#ccccd8" FontSize="10"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- Micro -->
                    <Grid ColumnDefinitions="52, *, 36" Margin="0,0,0,5">
                        <TextBlock Grid.Column="0" Text="Micro"
                                   Foreground="#8888a0" FontSize="10"
                                   VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                Value="{Binding MicVolume}"
                                VerticalAlignment="Center" Margin="4,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding MicVolumeDisplay}"
                                   Foreground="#ccccd8" FontSize="10"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <!-- Musique -->
                    <Grid ColumnDefinitions="52, *, 36">
                        <TextBlock Grid.Column="0" Text="Musique"
                                   Foreground="#8888a0" FontSize="10"
                                   VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                Value="{Binding MusicVolume}"
                                VerticalAlignment="Center" Margin="4,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding MusicVolumeDisplay}"
                                   Foreground="#ccccd8" FontSize="10"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Rectangle Grid.Column="3" Fill="Transparent"/>

            <!-- ── CONTRÔLES (Statut + Diffusion + Enregistrement) ── -->
            <Border Grid.Column="4" Background="#13131c" CornerRadius="8" Padding="10,8">
                <StackPanel Spacing="5">

                    <!-- Statut compact -->
                    <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,2">
                        <Border Grid.Column="0" Padding="5,2" CornerRadius="4"
                                Background="#09090f" BorderBrush="#2a2a38" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="7" Height="7" Fill="{Binding StreamStatusBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding StreamStatusText}"
                                           Foreground="{Binding StreamStatusBrush}"
                                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Grid.Column="1" Text="00:00:00"
                                   Foreground="{Binding StreamTimerBrush}"
                                   FontSize="12" FontFamily="Courier New"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="1080p"
                                   Foreground="#36364a" FontSize="10"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- DIFFUSION -->
                    <Button Content="GO LIVE"
                            IsVisible="{Binding !IsStreaming}"
                            Classes="ctrl-btn"
                            Height="30"
                            Background="#0e2420" Foreground="#34d399"
                            BorderBrush="#142e25">
                        <Button.Flyout>
                            <Flyout Placement="Top">
                                <StackPanel Width="280" Spacing="12" Margin="4">
                                    <TextBlock Text="DÉMARRER LE STREAM"
                                               FontSize="13" FontWeight="Bold" Foreground="#eaeaf0"/>
                                    <Rectangle Height="1" Fill="#36364a"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Scène" Foreground="#8888a0" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding SceneNames}"
                                                  SelectedIndex="{Binding StreamSceneIndex}"
                                                  Background="#1c1c28" BorderBrush="#36364a"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Plateforme" Foreground="#8888a0" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  SelectedIndex="{Binding StreamPlatformIndex}"
                                                  Background="#1c1c28" BorderBrush="#36364a">
                                            <ComboBoxItem Content="Twitch"/>
                                            <ComboBoxItem Content="YouTube Live"/>
                                            <ComboBoxItem Content="Facebook Live"/>
                                            <ComboBoxItem Content="RTMP Manuel"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Clé RTMP (optionnel)" Foreground="#5c5c72" FontSize="11"/>
                                        <TextBox PasswordChar="•"
                                                 Text="{Binding StreamRtmpKey}"
                                                 Watermark="rtmp://..."
                                                 Background="#1c1c28" BorderBrush="#36364a" Foreground="#ccccd8"/>
                                    </StackPanel>
                                    <Button Content="DÉMARRER"
                                            Command="{Binding StartStreamingCommand}"
                                            Classes="flyout-start"
                                            Background="#34d399" Foreground="#eaeaf0"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="ARRÊTER STREAM"
                            IsVisible="{Binding IsStreaming}"
                            Command="{Binding StopStreamingCommand}"
                            Classes="ctrl-btn"
                            Height="30"
                            Background="#251218" Foreground="#f87171"
                            BorderBrush="#2f1820"/>

                    <Rectangle Height="1" Fill="#2a2a38"/>

                    <!-- ENREGISTREMENT -->
                    <Button Content="ENREGISTRER"
                            IsVisible="{Binding !IsRecording}"
                            Classes="ctrl-btn"
                            Height="30"
                            Background="#2d1212" Foreground="#ef4444"
                            BorderBrush="#3d1a1a">
                        <Button.Flyout>
                            <Flyout Placement="Top">
                                <StackPanel Width="280" Spacing="12" Margin="4">
                                    <TextBlock Text="DÉMARRER L'ENREGISTREMENT"
                                               FontSize="13" FontWeight="Bold" Foreground="#eaeaf0"/>
                                    <Rectangle Height="1" Fill="#36364a"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Scène" Foreground="#8888a0" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding SceneNames}"
                                                  SelectedIndex="{Binding RecordSceneIndex}"
                                                  Background="#1c1c28" BorderBrush="#36364a"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Format de sortie" Foreground="#8888a0" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  SelectedIndex="{Binding RecordFormatIndex}"
                                                  Background="#1c1c28" BorderBrush="#36364a">
                                            <ComboBoxItem Content="MP4 (H.264 + AAC)"/>
                                            <ComboBoxItem Content="MKV (H.264 + AAC)"/>
                                            <ComboBoxItem Content="WebM (VP9 + Opus)"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <Button Content="DÉMARRER"
                                            Command="{Binding StartRecordingCommand}"
                                            Classes="flyout-start"
                                            Background="#ef4444" Foreground="#eaeaf0"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Content="ARRÊTER REC"
                            IsVisible="{Binding IsRecording}"
                            Command="{Binding StopRecordingCommand}"
                            Classes="ctrl-btn"
                            Height="30"
                            Background="#251218" Foreground="#f87171"
                            BorderBrush="#2f1820"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>

</UserControl>
