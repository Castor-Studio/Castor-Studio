<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels"
             xmlns:m="using:CastorApplication.Models"
             x:Class="CastorApplication.Views.StudioView"
             x:DataType="vm:StudioViewModel">

    <UserControl.Styles>

        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#6b7280"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="Button.ctrl-btn">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.flyout-start">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="*, 38, 250">

        <!-- ═══ VIDEO PREVIEW ═══ -->
        <Border Grid.Row="0"
                Background="#000000" Margin="8" CornerRadius="8"
                BorderBrush="#2a2a2a" BorderThickness="1">
            <Panel>
                <TextBlock Text="APERÇU VIDÉO"
                           Foreground="#1e1e1e" HorizontalAlignment="Center"
                           VerticalAlignment="Center" FontSize="22" FontWeight="Bold"/>

                <!-- Status badge -->
                <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                        Margin="12" Padding="10,6" CornerRadius="6"
                        Background="#0d0d14" BorderBrush="#2a2a2a" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Ellipse Width="8" Height="8" Fill="{Binding StreamStatusColor}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StreamStatusText}"
                                   Foreground="{Binding StreamStatusColor}"
                                   FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Timer -->
                <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Margin="12" Padding="8,4" CornerRadius="4"
                        Background="#0d0d0d" BorderBrush="#1a1a1a" BorderThickness="1">
                    <TextBlock Text="00:00:00"
                               Foreground="{Binding StreamTimerColor}"
                               FontSize="14" FontFamily="Courier New"/>
                </Border>

                <!-- Resolution -->
                <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
                        Margin="12" Padding="8,4" CornerRadius="4"
                        Background="#0d0d0d" BorderBrush="#1a1a1a" BorderThickness="1">
                    <TextBlock Text="1920 × 1080" Foreground="#333333" FontSize="12"/>
                </Border>
            </Panel>
        </Border>

        <!-- ═══ SCENE SELECTOR BAR ═══ -->
        <Border Grid.Row="1"
                Background="#1a1a1a" CornerRadius="6" Margin="8,0,8,4"
                Padding="12,0" BorderBrush="#2a2a2a" BorderThickness="1">
            <Grid ColumnDefinitions="Auto, Auto, *, Auto">
                <TextBlock Grid.Column="0" Text="SCÈNE ACTIVE :"
                           Foreground="#6b7280" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding SceneNames}"
                          SelectedIndex="{Binding SelectedSceneIndex}"
                          MinWidth="180" VerticalAlignment="Center"
                          Background="#1e1e1e" BorderBrush="#333333"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#22c55e" VerticalAlignment="Center"/>
                    <TextBlock Text="Prêt" Foreground="#22c55e" FontSize="11"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CONTROL BAR ═══ -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*, 8, 320, 8, 220"
              Margin="8,0,8,8">

            <!-- ── SOURCES ── -->
            <Border Grid.Column="0" Background="#1a1a1a" CornerRadius="8" Padding="14">
                <Grid RowDefinitions="Auto, 10, *">

                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                        <TextBlock Grid.Column="0" Text="SOURCES" Classes="section-header"
                                   VerticalAlignment="Center" Margin="0"/>
                        <Button Grid.Column="1" Content="+"
                                Command="{Binding AddSourceCommand}"
                                Background="#1e3a5f" Foreground="#3498db"
                                BorderThickness="0" Padding="10,4" CornerRadius="5"
                                FontSize="16" FontWeight="Bold" Cursor="Hand"/>
                    </Grid>

                    <Rectangle Grid.Row="1" Height="1" Fill="#2a2a2a"/>

                    <!-- Dynamic source list -->
                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding Sources}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:SourceItem">
                                    <Border Background="#1e1e1e" CornerRadius="5"
                                            Padding="10,8" Margin="0,0,0,4">
                                        <Grid ColumnDefinitions="12, *, Auto">
                                            <Ellipse Grid.Column="0" Width="7" Height="7"
                                                     Fill="{Binding Color}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       Foreground="#d1d5db" FontSize="13"
                                                       VerticalAlignment="Center" Margin="8,0"/>
                                            <Button Grid.Column="2" Content="✕"
                                                    Background="Transparent" Foreground="#4a4a4a"
                                                    BorderThickness="0" FontSize="11" Padding="4,2"
                                                    Cursor="Hand"
                                                    Command="{Binding $parent[UserControl].((vm:StudioViewModel)DataContext).RemoveSourceCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Rectangle Grid.Column="1" Fill="Transparent"/>

            <!-- ── AUDIO MIXER ── -->
            <Border Grid.Column="2" Background="#1a1a1a" CornerRadius="8" Padding="14">
                <Grid RowDefinitions="Auto, 10, *">

                    <TextBlock Grid.Row="0" Text="MIXEUR AUDIO" Classes="section-header"/>
                    <Rectangle Grid.Row="1" Height="1" Fill="#2a2a2a"/>

                    <StackPanel Grid.Row="2" Spacing="14">

                        <!-- Desktop Audio -->
                        <Grid ColumnDefinitions="90, *, 40">
                            <TextBlock Grid.Column="0" Text="Bureau"
                                       Foreground="#9ca3af" FontSize="12" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                    Value="{Binding DesktopVolume}"
                                    VerticalAlignment="Center" Margin="6,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding DesktopVolumeDisplay}"
                                       Foreground="#6b7280" FontSize="11"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Microphone -->
                        <Grid ColumnDefinitions="90, *, 40">
                            <TextBlock Grid.Column="0" Text="Microphone"
                                       Foreground="#9ca3af" FontSize="12" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                    Value="{Binding MicVolume}"
                                    VerticalAlignment="Center" Margin="6,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding MicVolumeDisplay}"
                                       Foreground="#6b7280" FontSize="11"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Music -->
                        <Grid ColumnDefinitions="90, *, 40">
                            <TextBlock Grid.Column="0" Text="Musique"
                                       Foreground="#9ca3af" FontSize="12" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                    Value="{Binding MusicVolume}"
                                    VerticalAlignment="Center" Margin="6,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding MusicVolumeDisplay}"
                                       Foreground="#6b7280" FontSize="11"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>

                    </StackPanel>
                </Grid>
            </Border>

            <Rectangle Grid.Column="3" Fill="Transparent"/>

            <!-- ── CONTROLS ── -->
            <Border Grid.Column="4" Background="#1a1a1a" CornerRadius="8" Padding="12">
                <StackPanel Spacing="6" VerticalAlignment="Center">

                    <!-- STREAMING -->
                    <TextBlock Text="DIFFUSION" Classes="section-header"/>

                    <!-- Start Stream (visible when not streaming) -->
                    <Button Content="GO LIVE"
                            IsVisible="{Binding !IsStreaming}"
                            Classes="ctrl-btn"
                            Background="#0d3322" Foreground="#22c55e"
                            BorderBrush="#164d31">
                        <Button.Flyout>
                            <Flyout Placement="Top">
                                <StackPanel Width="280" Spacing="12" Margin="4">
                                    <TextBlock Text="DÉMARRER LE STREAM"
                                               FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    <Rectangle Height="1" Fill="#333333"/>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Scène" Foreground="#9ca3af" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding SceneNames}"
                                                  SelectedIndex="{Binding StreamSceneIndex}"
                                                  Background="#1e1e1e" BorderBrush="#333333"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Plateforme" Foreground="#9ca3af" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  SelectedIndex="{Binding StreamPlatformIndex}"
                                                  Background="#1e1e1e" BorderBrush="#333333">
                                            <ComboBoxItem Content="Twitch"/>
                                            <ComboBoxItem Content="YouTube Live"/>
                                            <ComboBoxItem Content="Facebook Live"/>
                                            <ComboBoxItem Content="RTMP Manuel"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Clé RTMP (optionnel)" Foreground="#6b7280" FontSize="11"/>
                                        <TextBox PasswordChar="•"
                                                 Text="{Binding StreamRtmpKey}"
                                                 Watermark="rtmp://..."
                                                 Background="#1e1e1e" BorderBrush="#333333" Foreground="#d1d5db"/>
                                    </StackPanel>

                                    <Button Content="DÉMARRER"
                                            Command="{Binding StartStreamingCommand}"
                                            Classes="flyout-start"
                                            Background="#22c55e" Foreground="White"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Stop Stream (visible when streaming) -->
                    <Button Content="ARRÊTER STREAM"
                            IsVisible="{Binding IsStreaming}"
                            Command="{Binding StopStreamingCommand}"
                            Classes="ctrl-btn"
                            Background="#3a0d0d" Foreground="#ef4444"
                            BorderBrush="#5c1a1a"/>

                    <Rectangle Height="1" Fill="#2a2a2a" Margin="0,2"/>

                    <!-- RECORDING -->
                    <TextBlock Text="ENREGISTREMENT" Classes="section-header"/>

                    <!-- Start Recording (visible when not recording) -->
                    <Button Content="ENREGISTRER"
                            IsVisible="{Binding !IsRecording}"
                            Classes="ctrl-btn"
                            Background="#3a2200" Foreground="#f59e0b"
                            BorderBrush="#5c3700">
                        <Button.Flyout>
                            <Flyout Placement="Top">
                                <StackPanel Width="280" Spacing="12" Margin="4">
                                    <TextBlock Text="DÉMARRER L'ENREGISTREMENT"
                                               FontSize="13" FontWeight="Bold" Foreground="White"/>
                                    <Rectangle Height="1" Fill="#333333"/>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Scène" Foreground="#9ca3af" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding SceneNames}"
                                                  SelectedIndex="{Binding RecordSceneIndex}"
                                                  Background="#1e1e1e" BorderBrush="#333333"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Format de sortie" Foreground="#9ca3af" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  SelectedIndex="{Binding RecordFormatIndex}"
                                                  Background="#1e1e1e" BorderBrush="#333333">
                                            <ComboBoxItem Content="MP4 (H.264 + AAC)"/>
                                            <ComboBoxItem Content="MKV (H.264 + AAC)"/>
                                            <ComboBoxItem Content="WebM (VP9 + Opus)"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <Button Content="DÉMARRER"
                                            Command="{Binding StartRecordingCommand}"
                                            Classes="flyout-start"
                                            Background="#f59e0b" Foreground="White"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Stop Recording (visible when recording) -->
                    <Button Content="ARRÊTER REC"
                            IsVisible="{Binding IsRecording}"
                            Command="{Binding StopRecordingCommand}"
                            Classes="ctrl-btn"
                            Background="#3a0d0d" Foreground="#ef4444"
                            BorderBrush="#5c1a1a"/>

                </StackPanel>
            </Border>

        </Grid>
    </Grid>

</UserControl>
