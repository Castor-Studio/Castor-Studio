<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels"
             x:Class="CastorApplication.Views.StudioView"
             x:DataType="vm:StudioViewModel">

    <UserControl.Styles>

        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#6b7280"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style Selector="Button.ctrl-btn">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.add-btn">
            <Setter Property="Background" Value="#1e3a5f"/>
            <Setter Property="Foreground" Value="#3498db"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="*, 230">

        <!-- ═══ VIDEO PREVIEW ═══ -->
        <Border Grid.Row="0"
                Background="#000000"
                Margin="8"
                CornerRadius="8"
                BorderBrush="#2a2a2a"
                BorderThickness="1">
            <Panel>

                <!-- Placeholder text -->
                <TextBlock Text="APERÇU VIDÉO"
                           Foreground="#1e1e1e"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="22"
                           FontWeight="Bold"/>

                <!-- Status badge (top right) -->
                <Border VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="12"
                        Padding="10,6"
                        CornerRadius="6"
                        Background="#0d0d14"
                        BorderBrush="#2a2a2a"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Ellipse Width="8" Height="8" Fill="#555555" VerticalAlignment="Center"/>
                        <TextBlock Text="OFFLINE"
                                   Foreground="#555555"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Timer (bottom left) -->
                <Border VerticalAlignment="Bottom"
                        HorizontalAlignment="Left"
                        Margin="12"
                        Padding="8,4"
                        CornerRadius="4"
                        Background="#0d0d0d"
                        BorderBrush="#1a1a1a"
                        BorderThickness="1">
                    <TextBlock Text="00:00:00"
                               Foreground="#333333"
                               FontSize="14"
                               FontFamily="Courier New"/>
                </Border>

                <!-- Resolution indicator (bottom right) -->
                <Border VerticalAlignment="Bottom"
                        HorizontalAlignment="Right"
                        Margin="12"
                        Padding="8,4"
                        CornerRadius="4"
                        Background="#0d0d0d"
                        BorderBrush="#1a1a1a"
                        BorderThickness="1">
                    <TextBlock Text="1920 × 1080"
                               Foreground="#333333"
                               FontSize="12"/>
                </Border>

            </Panel>
        </Border>

        <!-- ═══ CONTROL BAR ═══ -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*, 8, 320, 8, 200"
              Margin="8,0,8,8">

            <!-- ── SOURCES ── -->
            <Border Grid.Column="0"
                    Background="#1a1a1a"
                    CornerRadius="8"
                    Padding="14">
                <Grid RowDefinitions="Auto, 10, *">

                    <!-- Header -->
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                        <TextBlock Grid.Column="0"
                                   Text="SOURCES"
                                   Classes="section-header"
                                   VerticalAlignment="Center"
                                   Margin="0"/>
                        <Button Grid.Column="1"
                                Content="+"
                                Classes="add-btn"/>
                    </Grid>

                    <!-- Divider -->
                    <Rectangle Grid.Row="1" Height="1" Fill="#2a2a2a"/>

                    <!-- Source list -->
                    <StackPanel Grid.Row="2" Spacing="4">

                        <!-- Screen capture (active) -->
                        <Border Background="#1e1e1e"
                                CornerRadius="5"
                                Padding="10,8">
                            <Grid ColumnDefinitions="12, *, Auto">
                                <Ellipse Grid.Column="0"
                                         Width="7" Height="7"
                                         Fill="#3498db"
                                         VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="Capture d'écran"
                                           Foreground="#d1d5db"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="8,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="✕"
                                           Foreground="#4a4a4a"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Cursor="Hand"/>
                            </Grid>
                        </Border>

                        <!-- Camera (active) -->
                        <Border Background="#1e1e1e"
                                CornerRadius="5"
                                Padding="10,8">
                            <Grid ColumnDefinitions="12, *, Auto">
                                <Ellipse Grid.Column="0"
                                         Width="7" Height="7"
                                         Fill="#22c55e"
                                         VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="Caméra principale"
                                           Foreground="#d1d5db"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="8,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="✕"
                                           Foreground="#4a4a4a"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           Cursor="Hand"/>
                            </Grid>
                        </Border>

                        <!-- Game capture (inactive) -->
                        <Border Background="Transparent"
                                CornerRadius="5"
                                Padding="10,8">
                            <Grid ColumnDefinitions="12, *, Auto">
                                <Ellipse Grid.Column="0"
                                         Width="7" Height="7"
                                         Fill="#333333"
                                         VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="Capture de jeu"
                                           Foreground="#4a4a4a"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Margin="8,0"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Spacer -->
            <Rectangle Grid.Column="1" Fill="Transparent"/>

            <!-- ── AUDIO MIXER ── -->
            <Border Grid.Column="2"
                    Background="#1a1a1a"
                    CornerRadius="8"
                    Padding="14">
                <Grid RowDefinitions="Auto, 10, *">

                    <TextBlock Grid.Row="0"
                               Text="MIXEUR AUDIO"
                               Classes="section-header"/>

                    <Rectangle Grid.Row="1" Height="1" Fill="#2a2a2a"/>

                    <StackPanel Grid.Row="2" Spacing="14">

                        <!-- Desktop Audio -->
                        <Grid ColumnDefinitions="90, *, 40">
                            <TextBlock Grid.Column="0"
                                       Text="Bureau"
                                       Foreground="#9ca3af"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="100" Value="80"
                                    VerticalAlignment="Center"
                                    Margin="6,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="80%"
                                       Foreground="#6b7280"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Microphone -->
                        <Grid ColumnDefinitions="90, *, 40">
                            <TextBlock Grid.Column="0"
                                       Text="Microphone"
                                       Foreground="#9ca3af"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="100" Value="65"
                                    VerticalAlignment="Center"
                                    Margin="6,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="65%"
                                       Foreground="#6b7280"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Music -->
                        <Grid ColumnDefinitions="90, *, 40">
                            <TextBlock Grid.Column="0"
                                       Text="Musique"
                                       Foreground="#9ca3af"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1"
                                    Minimum="0" Maximum="100" Value="30"
                                    VerticalAlignment="Center"
                                    Margin="6,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="30%"
                                       Foreground="#6b7280"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Spacer -->
            <Rectangle Grid.Column="3" Fill="Transparent"/>

            <!-- ── CONTROLS ── -->
            <Border Grid.Column="4"
                    Background="#1a1a1a"
                    CornerRadius="8"
                    Padding="14">
                <StackPanel Spacing="8" VerticalAlignment="Center">

                    <!-- Streaming section -->
                    <TextBlock Text="DIFFUSION" Classes="section-header"/>

                    <Button Content="GO LIVE"
                            Classes="ctrl-btn"
                            Background="#0d3322"
                            Foreground="#22c55e"
                            BorderBrush="#164d31"/>
                    <!--Command="{Binding GoLiveCommand}"-->

                    <Button Content="ARRÊTER"
                            Classes="ctrl-btn"
                            Background="#3a0d0d"
                            Foreground="#ef4444"
                            BorderBrush="#5c1a1a"/>
                    <!--Command="{Binding StopLiveCommand}"-->

                    <!-- Divider -->
                    <Rectangle Height="1" Fill="#2a2a2a" Margin="0,4"/>

                    <!-- Recording section -->
                    <TextBlock Text="ENREGISTREMENT" Classes="section-header"/>

                    <Button Content="ENREGISTRER"
                            Classes="ctrl-btn"
                            Background="#3a2200"
                            Foreground="#f59e0b"
                            BorderBrush="#5c3700"/>
                    <!--Command="{Binding StartRecordCommand}"-->

                </StackPanel>
            </Border>

        </Grid>
    </Grid>

</UserControl>
