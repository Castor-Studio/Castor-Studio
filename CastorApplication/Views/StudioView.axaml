<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels"
             xmlns:m="using:CastorApplication.Models"
             xmlns:dock="using:Dock.Avalonia.Controls"
             x:Class="CastorApplication.Views.StudioView"
             x:DataType="vm:StudioViewModel">

    <UserControl.Styles>

        <Style Selector="TextBlock.section-header">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg4}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="LetterSpacing" Value="1"/>
        </Style>

        <Style Selector="Button.ctrl-btn">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.flyout-start">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="*, 38, 72">

        <!-- ═══ ZONE PRINCIPALE : DockControl (Preview + Outils déplaçables) ═══ -->
        <dock:DockControl Grid.Row="0" Layout="{Binding Layout}">

            <dock:DockControl.DataTemplates>

                <!-- ── PREVIEW VIDÉO (contexte = StudioViewModel) ── -->
                <DataTemplate x:DataType="vm:StudioViewModel">
                    <Panel Background="{DynamicResource AppSurface3}">
                        <TextBlock Text="APERÇU VIDÉO"
                                   Foreground="{DynamicResource AppSurface2}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="22" FontWeight="Bold" LetterSpacing="3"/>

                        <!-- Badge statut (haut droite) -->
                        <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                Margin="10" Padding="8,4" CornerRadius="4"
                                Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Ellipse Width="7" Height="7" Fill="{Binding StreamStatusBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding StreamStatusText}"
                                           Foreground="{Binding StreamStatusBrush}"
                                           FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Timer (bas gauche) -->
                        <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                   Margin="14,0,0,12" Text="00:00:00"
                                   Foreground="{Binding StreamTimerBrush}"
                                   FontSize="16" FontFamily="Courier New"/>
                    </Panel>
                </DataTemplate>

                <!-- ── SOURCES (contexte = SourcesPanelContext) ── -->
                <DataTemplate x:DataType="vm:SourcesPanelContext">
                    <Grid RowDefinitions="*, Auto" Margin="8,6">

                        <ListBox Grid.Row="0"
                                 ItemsSource="{Binding Studio.Sources}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="4,3"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="m:SourceItem">
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Ellipse Grid.Column="0" Width="7" Height="7"
                                                 Fill="{Binding ColorBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,7,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   Foreground="{DynamicResource AppFg2}" FontSize="12"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Type}"
                                                   Foreground="{DynamicResource AppFg4}" FontSize="10"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button Grid.Row="1"
                                Content="+ Ajouter une source"
                                Command="{Binding Studio.AddSourceCommand}"
                                Height="28" FontSize="11"
                                Background="{DynamicResource AppSurface2}" Foreground="{DynamicResource AppFg3}"
                                BorderBrush="{DynamicResource AppBorder2}" BorderThickness="1"
                                CornerRadius="5" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Margin="0,4,0,0" Cursor="Hand"/>
                    </Grid>
                </DataTemplate>

                <!-- ── MIXER AUDIO (contexte = AudioPanelContext) ── -->
                <DataTemplate x:DataType="vm:AudioPanelContext">
                    <StackPanel VerticalAlignment="Center" Spacing="10" Margin="10,8">

                        <!-- Bureau -->
                        <Grid ColumnDefinitions="56, *, 38">
                            <TextBlock Grid.Column="0" Text="Bureau"
                                       Foreground="{DynamicResource AppFg3}" FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                    Value="{Binding Studio.DesktopVolume}"
                                    VerticalAlignment="Center" Margin="4,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Studio.DesktopVolumeDisplay}"
                                       Foreground="{DynamicResource AppFg2}" FontSize="11"
                                       VerticalAlignment="Center" TextAlignment="Right"/>
                        </Grid>

                        <!-- Micro -->
                        <Grid ColumnDefinitions="56, *, 38">
                            <TextBlock Grid.Column="0" Text="Micro"
                                       Foreground="{DynamicResource AppFg3}" FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                    Value="{Binding Studio.MicVolume}"
                                    VerticalAlignment="Center" Margin="4,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Studio.MicVolumeDisplay}"
                                       Foreground="{DynamicResource AppFg2}" FontSize="11"
                                       VerticalAlignment="Center" TextAlignment="Right"/>
                        </Grid>

                        <!-- Musique -->
                        <Grid ColumnDefinitions="56, *, 38">
                            <TextBlock Grid.Column="0" Text="Musique"
                                       Foreground="{DynamicResource AppFg3}" FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                    Value="{Binding Studio.MusicVolume}"
                                    VerticalAlignment="Center" Margin="4,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Studio.MusicVolumeDisplay}"
                                       Foreground="{DynamicResource AppFg2}" FontSize="11"
                                       VerticalAlignment="Center" TextAlignment="Right"/>
                        </Grid>

                    </StackPanel>
                </DataTemplate>

            </dock:DockControl.DataTemplates>
        </dock:DockControl>

        <!-- ═══ SCENE SELECTOR BAR ═══ -->
        <Border Grid.Row="1"
                Background="{DynamicResource AppSurface}" CornerRadius="6" Margin="8,4,8,4"
                Padding="12,0" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
            <Grid ColumnDefinitions="Auto, Auto, *, Auto">
                <TextBlock Grid.Column="0" Text="SCÈNE ACTIVE :"
                           Foreground="{DynamicResource AppFg4}" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding SceneNames}"
                          SelectedIndex="{Binding SelectedSceneIndex}"
                          MinWidth="180" VerticalAlignment="Center"
                          Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#34d399" VerticalAlignment="Center"/>
                    <TextBlock Text="Prêt" Foreground="#34d399" FontSize="11"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ BARRE DE CONTRÔLES ═══ -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*, 8, 220"
              Margin="8,0,8,8">

            <!-- ── STATUT ── -->
            <Border Grid.Column="0" Background="{DynamicResource AppSurface}" CornerRadius="8" Padding="12,0"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                <Grid ColumnDefinitions="Auto, *, Auto">

                    <Border Grid.Column="0" Padding="8,4" CornerRadius="5"
                            Background="{DynamicResource AppSurface3}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Ellipse Width="7" Height="7" Fill="{Binding StreamStatusBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StreamStatusText}"
                                       Foreground="{Binding StreamStatusBrush}"
                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Column="1" Text="00:00:00"
                               Foreground="{Binding StreamTimerBrush}"
                               FontSize="14" FontFamily="Courier New"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="2" Text="1920 × 1080"
                               Foreground="{DynamicResource AppFg6}" FontSize="11"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Rectangle Grid.Column="1" Fill="Transparent"/>

            <!-- ── BOUTONS DIFFUSION + ENREGISTREMENT ── -->
            <Border Grid.Column="2" Background="{DynamicResource AppSurface}" CornerRadius="8" Padding="10,8"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                <Grid ColumnDefinitions="*, 6, *" VerticalAlignment="Center">

                    <!-- GO LIVE / STOP STREAM -->
                    <Button Grid.Column="0"
                            Content="GO LIVE"
                            IsVisible="{Binding !IsStreaming}"
                            Classes="ctrl-btn"
                            Background="{DynamicResource AppLiveBg}" Foreground="#34d399"
                            BorderBrush="{DynamicResource AppLiveBorder}">
                        <Button.Flyout>
                            <Flyout Placement="Top">
                                <StackPanel Width="280" Spacing="12" Margin="4">
                                    <TextBlock Text="DÉMARRER LE STREAM"
                                               FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AppFg1}"/>
                                    <Rectangle Height="1" Fill="{DynamicResource AppBorder2}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Scène" Foreground="{DynamicResource AppFg3}" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding SceneNames}"
                                                  SelectedIndex="{Binding StreamSceneIndex}"
                                                  Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Plateforme" Foreground="{DynamicResource AppFg3}" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  SelectedIndex="{Binding StreamPlatformIndex}"
                                                  Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}">
                                            <ComboBoxItem Content="Twitch"/>
                                            <ComboBoxItem Content="YouTube Live"/>
                                            <ComboBoxItem Content="Facebook Live"/>
                                            <ComboBoxItem Content="RTMP Manuel"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Clé RTMP (optionnel)" Foreground="{DynamicResource AppFg4}" FontSize="11"/>
                                        <TextBox PasswordChar="•" Text="{Binding StreamRtmpKey}"
                                                 Watermark="rtmp://..."
                                                 Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}" Foreground="{DynamicResource AppFg2}"/>
                                    </StackPanel>
                                    <Button Content="DÉMARRER"
                                            Command="{Binding StartStreamingCommand}"
                                            Classes="flyout-start"
                                            Background="#34d399" Foreground="#0b0b12"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Grid.Column="0"
                            Content="STOP STREAM"
                            IsVisible="{Binding IsStreaming}"
                            Command="{Binding StopStreamingCommand}"
                            Classes="ctrl-btn"
                            Background="{DynamicResource AppStopBg}" Foreground="#f87171"
                            BorderBrush="{DynamicResource AppStopBorder}"/>

                    <!-- ENREGISTRER / STOP REC -->
                    <Button Grid.Column="2"
                            Content="ENREGISTRER"
                            IsVisible="{Binding !IsRecording}"
                            Classes="ctrl-btn"
                            Background="{DynamicResource AppRecBg}" Foreground="#ef4444"
                            BorderBrush="{DynamicResource AppRecBorder}">
                        <Button.Flyout>
                            <Flyout Placement="Top">
                                <StackPanel Width="280" Spacing="12" Margin="4">
                                    <TextBlock Text="DÉMARRER L'ENREGISTREMENT"
                                               FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AppFg1}"/>
                                    <Rectangle Height="1" Fill="{DynamicResource AppBorder2}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Scène" Foreground="{DynamicResource AppFg3}" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding SceneNames}"
                                                  SelectedIndex="{Binding RecordSceneIndex}"
                                                  Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Format de sortie" Foreground="{DynamicResource AppFg3}" FontSize="11"/>
                                        <ComboBox HorizontalAlignment="Stretch"
                                                  SelectedIndex="{Binding RecordFormatIndex}"
                                                  Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}">
                                            <ComboBoxItem Content="MP4 (H.264 + AAC)"/>
                                            <ComboBoxItem Content="MKV (H.264 + AAC)"/>
                                            <ComboBoxItem Content="WebM (VP9 + Opus)"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <Button Content="DÉMARRER"
                                            Command="{Binding StartRecordingCommand}"
                                            Classes="flyout-start"
                                            Background="#ef4444" Foreground="#eaeaf0"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Grid.Column="2"
                            Content="STOP REC"
                            IsVisible="{Binding IsRecording}"
                            Command="{Binding StopRecordingCommand}"
                            Classes="ctrl-btn"
                            Background="{DynamicResource AppStopBg}" Foreground="#f87171"
                            BorderBrush="{DynamicResource AppStopBorder}"/>

                </Grid>
            </Border>

        </Grid>
    </Grid>

</UserControl>
