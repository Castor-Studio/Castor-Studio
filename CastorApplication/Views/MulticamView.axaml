<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels"
             xmlns:m="using:CastorApplication.Models"
             xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
             x:Class="CastorApplication.Views.MulticamView"
             x:DataType="vm:MulticamViewModel">

    <UserControl.Styles>

        <Style Selector="Button.ai-mode">
            <Setter Property="Background" Value="{DynamicResource AppSurface2}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg4}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.ai-mode:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppBadgeBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg2}"/>
        </Style>

        <Style Selector="Button.ai-active">
            <Setter Property="Background" Value="{DynamicResource AppAccentBg}"/>
            <Setter Property="Foreground" Value="#5b8def"/>
            <Setter Property="BorderBrush" Value="#5b8def"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="56, Auto, *" Background="{DynamicResource AppBg}">

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid ColumnDefinitions="*, Auto">

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="MULTI-CAMÉRAS"
                               FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AppFg1}"
                               VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource AppBadgeBg}" CornerRadius="10" Padding="8,3"
                            IsVisible="{Binding HasCameras}">
                        <TextBlock Text="{Binding Cameras.Count, StringFormat='{}{0} sources'}"
                                   FontSize="11" Foreground="{DynamicResource AppFg4}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">

                    <Button Content="+ CHOISIR DES VIDÉOS"
                            Command="{Binding LoadVideoFilesCommand}"
                            Background="{DynamicResource AppAccentBg}" Foreground="#5b8def"
                            BorderThickness="0" Padding="14,8" CornerRadius="6"
                            FontSize="12" FontWeight="SemiBold"
                            Cursor="Hand"/>

                    <Button Content="EFFACER"
                            Command="{Binding ClearCamerasCommand}"
                            IsVisible="{Binding HasCameras}"
                            Background="{DynamicResource AppSurface2}" Foreground="{DynamicResource AppFg4}"
                            BorderBrush="{DynamicResource AppBorder2}" BorderThickness="1"
                            Padding="12,8" CornerRadius="6"
                            FontSize="11" FontWeight="SemiBold" Cursor="Hand"/>

                </StackPanel>

            </Grid>
        </Border>

        <!-- ═══ AI MODE BAR ═══ -->
        <Border Grid.Row="1"
                Background="{DynamicResource AppSurface3}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto, *">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center">
                    <TextBlock Text="IA :" Foreground="{DynamicResource AppFg3}" FontSize="12"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button IsVisible="{Binding IsAiOff}"
                                Content="DÉSACTIVÉ"
                                Background="{DynamicResource AppBadgeBg}" Foreground="{DynamicResource AppFg3}"
                                BorderBrush="{DynamicResource AppBorder2}" BorderThickness="1"
                                Padding="12,6" CornerRadius="6"
                                FontSize="11" FontWeight="SemiBold" Cursor="Hand"/>
                        <Button IsVisible="{Binding !IsAiOff}"
                                Content="DÉSACTIVÉ"
                                Command="{Binding SetAiOffCommand}"
                                Classes="ai-mode"/>

                        <Button IsVisible="{Binding IsAiAuto}"
                                Content="MODE AUTO"
                                Classes="ai-active"/>
                        <Button IsVisible="{Binding !IsAiAuto}"
                                Content="MODE AUTO"
                                Command="{Binding SetAiAutoCommand}"
                                Classes="ai-mode"/>
                    </StackPanel>

                    <Border IsVisible="{Binding AiStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                            Background="{DynamicResource AppSurface2}"
                            CornerRadius="4" Padding="10,4" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse Width="6" Height="6" Fill="#5b8def"
                                     IsVisible="{Binding IsAiRunning}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AiStatus}"
                                       Foreground="{DynamicResource AppFg3}" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ═══ MAIN AREA : empty state OR (BIG output | source thumbnails) ═══ -->
        <Grid Grid.Row="2">

            <!-- Empty state -->
            <Border IsVisible="{Binding HasNoCameras}" Padding="40">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14"
                            MaxWidth="500">
                    <Border Background="{DynamicResource AppSurface2}" CornerRadius="40"
                            Width="72" Height="72" HorizontalAlignment="Center">
                        <TextBlock Text="🎬" FontSize="34"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Aucune source chargée"
                               HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppFg2}"/>
                    <TextBlock Text="Sélectionne au moins 2 vidéos. L'IA détectera qui parle et alternera entre les caméras automatiquement. La sortie live s'affichera à gauche, les sources brutes à droite."
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                               FontSize="12" Foreground="{DynamicResource AppFg5}"/>
                    <Button Content="+ Choisir des vidéos"
                            Command="{Binding LoadVideoFilesCommand}"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource AppAccentBg}" Foreground="#5b8def"
                            BorderThickness="0" Padding="18,10" CornerRadius="6"
                            FontSize="12" FontWeight="SemiBold" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <!-- Live workspace -->
            <Grid IsVisible="{Binding HasCameras}" ColumnDefinitions="3*, 1*" Margin="12">

                <!-- ── BIG : AI output (Studio in disguise) ───────────────── -->
                <Border Grid.Column="0" Background="Black" CornerRadius="8" ClipToBounds="True"
                        Margin="0,0,8,0">
                    <Panel>

                        <Image Source="{Binding ActiveThumbnail}"
                               Stretch="Uniform"
                               IsVisible="{Binding ActiveThumbnail, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                        <vlc:VideoView MediaPlayer="{Binding ActiveMediaPlayer}"
                                       IsVisible="{Binding ActiveMediaPlayer, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                        <StackPanel IsVisible="{Binding ActiveThumbnail, Converter={x:Static ObjectConverters.IsNull}}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                            <TextBlock Text="SORTIE IA" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource AppFg5}"
                                       HorizontalAlignment="Center" LetterSpacing="2"/>
                            <TextBlock Text="Importe 2 vidéos puis MODE AUTO"
                                       FontSize="12" Foreground="{DynamicResource AppFg6}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- ON-AIR badge -->
                        <Border IsVisible="{Binding IsAiRunning}"
                                VerticalAlignment="Top" HorizontalAlignment="Left"
                                Margin="14" Padding="9,4" CornerRadius="4"
                                Background="#dc2626">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="7" Height="7" Fill="#eaeaf0" VerticalAlignment="Center"/>
                                <TextBlock Text="ON AIR" FontSize="10" FontWeight="Bold" Foreground="#eaeaf0"/>
                            </StackPanel>
                        </Border>

                        <!-- Active-source label -->
                        <Border IsVisible="{Binding IsAiRunning}"
                                VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                Margin="14" Padding="10,5" CornerRadius="4"
                                Background="#AA0B0B12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                            <TextBlock Text="{Binding AiStatus}"
                                       Foreground="#eaeaf0" FontSize="11" FontWeight="SemiBold"/>
                        </Border>

                    </Panel>
                </Border>

                <!-- ── RIGHT : source previews stack ───────────────────────── -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Cameras}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" Spacing="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:CameraItem">
                                <Border CornerRadius="8" ClipToBounds="True">
                                    <Panel>

                                        <Border Background="Black" CornerRadius="8" Height="170">
                                            <Panel>
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="UniformToFill"
                                                       IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                <vlc:VideoView MediaPlayer="{Binding MediaPlayer}"
                                                               IsVisible="{Binding MediaPlayer, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                <TextBlock Text="{Binding Label}"
                                                           IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"
                                                           Foreground="{DynamicResource AppSurface2}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontSize="28" FontWeight="Bold"/>
                                            </Panel>
                                        </Border>

                                        <!-- Cam label -->
                                        <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                Margin="6" Padding="6,2" CornerRadius="4"
                                                Background="#80000000">
                                            <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="Bold" Foreground="#eaeaf0"/>
                                        </Border>

                                        <!-- LIVE badge -->
                                        <Border IsVisible="{Binding IsLive}"
                                                VerticalAlignment="Top" HorizontalAlignment="Left"
                                                Margin="6" Padding="6,2" CornerRadius="4"
                                                Background="#5b8def">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <Ellipse Width="5" Height="5" Fill="#eaeaf0" VerticalAlignment="Center"/>
                                                <TextBlock Text="LIVE" FontSize="9" FontWeight="Bold" Foreground="#eaeaf0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Filename strip -->
                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                                Padding="8,4" Background="#CC0B0B12">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{DynamicResource AppFg3}"
                                                       FontSize="10" TextTrimming="CharacterEllipsis"/>
                                        </Border>

                                        <!-- Active glow border -->
                                        <Border IsVisible="{Binding IsActive}"
                                                BorderBrush="#5b8def" BorderThickness="2"
                                                CornerRadius="8" IsHitTestVisible="False"/>

                                    </Panel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>

        </Grid>

    </Grid>

</UserControl>
