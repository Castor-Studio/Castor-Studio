<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels"
             x:Class="CastorApplication.Views.MulticamView"
             x:DataType="vm:MulticamViewModel">

    <UserControl.Styles>

        <Style Selector="Button.ai-mode">
            <Setter Property="Background" Value="{DynamicResource AppSurface2}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg4}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.ai-mode:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppBadgeBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg2}"/>
        </Style>

        <Style Selector="Button.ai-active">
            <Setter Property="Background" Value="{DynamicResource AppAccentBg}"/>
            <Setter Property="Foreground" Value="#5b8def"/>
            <Setter Property="BorderBrush" Value="#5b8def"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="56, Auto, *" Background="{DynamicResource AppBg}">

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="MULTI-CAMÉRAS"
                               FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AppFg1}"
                               VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource AppBadgeBg}" CornerRadius="10" Padding="8,3">
                        <TextBlock Text="{Binding Scenes.Count, StringFormat='{}{0} scènes'}"
                                   FontSize="11" Foreground="{DynamicResource AppFg4}"/>
                    </Border>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="ACTUALISER"
                        Command="{Binding RefreshAiScenesCommand}"
                        Background="{DynamicResource AppAccentBg}" Foreground="#5b8def"
                        BorderThickness="0" Padding="14,8" CornerRadius="6"
                        FontSize="12" FontWeight="SemiBold"
                        VerticalAlignment="Center" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource AppSurface3}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid ColumnDefinitions="Auto, *, Auto">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                            VerticalAlignment="Center">
                    <TextBlock Text="IA :" Foreground="{DynamicResource AppFg3}" FontSize="12"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button IsVisible="{Binding IsAiOff}"
                                Content="DÉSACTIVÉ"
                                Background="{DynamicResource AppBadgeBg}" Foreground="{DynamicResource AppFg3}"
                                BorderBrush="{DynamicResource AppBorder2}" BorderThickness="1"
                                Padding="12,6" CornerRadius="6"
                                FontSize="11" FontWeight="SemiBold" Cursor="Hand"/>
                        <Button IsVisible="{Binding !IsAiOff}"
                                Content="DÉSACTIVÉ"
                                Command="{Binding SetAiOffCommand}"
                                IsEnabled="{Binding !IsAiBusy}"
                                Classes="ai-mode"/>

                        <Button IsVisible="{Binding IsAiAgent}"
                                Content="MODE AGENT"
                                Classes="ai-active"/>
                        <Button IsVisible="{Binding !IsAiAgent}"
                                Content="MODE AGENT"
                                Command="{Binding SetAiAgentCommand}"
                                IsEnabled="{Binding !IsAiBusy}"
                                Classes="ai-mode"/>

                        <Button IsVisible="{Binding IsAiAuto}"
                                Content="MODE AUTO"
                                Classes="ai-active"/>
                        <Button IsVisible="{Binding !IsAiAuto}"
                                Content="MODE AUTO"
                                Command="{Binding SetAiAutoCommand}"
                                IsEnabled="{Binding !IsAiBusy}"
                                Classes="ai-mode"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="#34d399" VerticalAlignment="Center"
                             IsVisible="{Binding IsAiEnabled}"/>
                    <TextBlock Text="{Binding AiStatusText}" Foreground="{DynamicResource AppFg3}"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="Modèle IA :" Foreground="{DynamicResource AppFg4}"
                               FontSize="11" VerticalAlignment="Center"/>
                    <ComboBox MinWidth="180"
                              SelectedIndex="{Binding SelectedAiModelIndex}"
                              IsEnabled="{Binding !IsAiEnabled}"
                              Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}" FontSize="12">
                        <ComboBoxItem Content="Football"/>
                        <ComboBoxItem Content="Podcast"/>
                    </ComboBox>
                </StackPanel>

            </Grid>
        </Border>

        <Grid Grid.Row="2" RowDefinitions="Auto, *" Margin="16">
            <Border Grid.Row="0"
                    IsVisible="{Binding AiError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    Background="#3b1219" BorderBrush="#7f1d1d" BorderThickness="1"
                    CornerRadius="6" Padding="10,7" Margin="0,0,0,12">
                <TextBlock Text="{Binding AiError}" Foreground="#f87171"
                           FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding AiScenes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:AiSceneSelection">
                            <Border Width="290" Height="150"
                                    Background="{DynamicResource AppSurface}"
                                    CornerRadius="8" Margin="0,0,12,12"
                                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                                <Grid RowDefinitions="*, Auto" Margin="12">
                                    <StackPanel Grid.Row="0" Spacing="8">
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  FontSize="13" FontWeight="SemiBold"
                                                  Foreground="{DynamicResource AppFg1}">
                                            <TextBlock Text="{Binding Name}" TextWrapping="Wrap"/>
                                        </CheckBox>
                                        <TextBlock Text="{Binding SourceCount, StringFormat='{}{0} source(s)'}"
                                                   Foreground="{DynamicResource AppFg4}" FontSize="11"/>
                                    </StackPanel>

                                    <Border Grid.Row="1"
                                            Background="{DynamicResource AppBadgeBg}" CornerRadius="4" Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="SCÈNE CASTOR" Foreground="{DynamicResource AppFg3}"
                                                   FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
