<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels"
             xmlns:m="using:CastorApplication.Models"
             x:Class="CastorApplication.Views.ScenesView"
             x:DataType="vm:ScenesViewModel">

    <UserControl.Styles>

        <Style Selector="Button.source-type-btn">
            <Setter Property="Background" Value="#0a2540"/>
            <Setter Property="Foreground" Value="#d8dfe8"/>
            <Setter Property="BorderBrush" Value="#1a4060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.source-type-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0d2a45"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.scene-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.scene-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0a2540"/>
        </Style>

    </UserControl.Styles>

    <Grid ColumnDefinitions="240, 1, *" Background="#011028">

        <!-- ═══ SCENES LIST ═══ -->
        <Border Grid.Column="0" Background="#002137">
            <Grid RowDefinitions="56, 1, *">

                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="14,0">
                    <TextBlock Grid.Column="0" Text="SCÈNES"
                               FontSize="11" FontWeight="Bold" Foreground="#6b7a8d"
                               VerticalAlignment="Center"/>

                    <!-- Create Scene Flyout -->
                    <Button Grid.Column="1"
                            Content="+"
                            Background="#2a0028" Foreground="#c96cc0"
                            BorderThickness="0" Padding="10,4" CornerRadius="5"
                            FontSize="16" FontWeight="Bold"
                            VerticalAlignment="Center" Cursor="Hand">
                        <Button.Flyout>
                            <Flyout Placement="Right">
                                <StackPanel Width="260" Spacing="12" Margin="4">
                                    <TextBlock Text="NOUVELLE SCÈNE"
                                               FontSize="13" FontWeight="Bold" Foreground="#f0f0f0"/>
                                    <Rectangle Height="1" Fill="#1a4060"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Nom de la scène" Foreground="#a1b1c8" FontSize="11"/>
                                        <TextBox Text="{Binding NewSceneName}"
                                                 Watermark="Ex: Match Live"
                                                 Background="#0a2540" BorderBrush="#1a4060" Foreground="#d8dfe8"/>
                                    </StackPanel>
                                    <Button Content="CRÉER LA SCÈNE"
                                            Command="{Binding CreateSceneCommand}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Height="36" Background="#c96cc0" Foreground="#f0f0f0"
                                            BorderThickness="0" CornerRadius="6"
                                            FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

                <Rectangle Grid.Row="1" Fill="#0d3450"/>

                <!-- Dynamic scene list -->
                <ScrollViewer Grid.Row="2">
                    <ItemsControl ItemsSource="{Binding Scenes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:SceneItem">
                                <Button Classes="scene-btn"
                                        Command="{Binding $parent[UserControl].((vm:ScenesViewModel)DataContext).SelectSceneCommand}"
                                        CommandParameter="{Binding}">
                                    <Panel>
                                        <!-- Active scene display -->
                                        <Border IsVisible="{Binding IsActive}"
                                                Background="#180d2a"
                                                BorderBrush="#c96cc0"
                                                BorderThickness="3,0,0,0">
                                            <Grid ColumnDefinitions="*, Auto" Margin="14,10,10,10">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="▶" Foreground="#c96cc0" FontSize="10"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}" Foreground="#f0f0f0"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        IsVisible="{Binding IsLive}"
                                                        Background="#c96cc0" CornerRadius="3" Padding="6,2">
                                                    <TextBlock Text="EN DIRECT" Foreground="#f0f0f0"
                                                               FontSize="9" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <!-- Inactive scene display -->
                                        <Border IsVisible="{Binding !IsActive}"
                                                Padding="14,10">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="#a1b1c8" FontSize="13"/>
                                        </Border>
                                    </Panel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Border>

        <Rectangle Grid.Column="1" Fill="#0d3450"/>

        <!-- ═══ RIGHT PANEL ═══ -->
        <Grid Grid.Column="2" RowDefinitions="*, 8, 200" Margin="8">

            <!-- Scene preview -->
            <Border Grid.Row="0"
                    Background="#00081a" CornerRadius="8"
                    BorderBrush="#0d3450" BorderThickness="1">
                <Panel>
                    <TextBlock Text="APERÇU DE LA SCÈNE"
                               Foreground="#0a2540" HorizontalAlignment="Center"
                               VerticalAlignment="Center" FontSize="18" FontWeight="Bold"/>

                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                            Margin="12" Padding="10,6" CornerRadius="5"
                            Background="#000d1a" BorderBrush="#0d3450" BorderThickness="1">
                        <TextBlock Text="{Binding SelectedScene.Name}"
                                   Foreground="#a1b1c8" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </Panel>
            </Border>

            <Rectangle Grid.Row="1" Fill="Transparent"/>

            <!-- Sources of selected scene -->
            <Border Grid.Row="2" Background="#002137" CornerRadius="8" Padding="14">
                <Grid RowDefinitions="Auto, 10, *">

                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                        <TextBlock Grid.Column="0" Text="SOURCES DE LA SCÈNE"
                                   FontSize="11" FontWeight="Bold" Foreground="#6b7a8d"
                                   VerticalAlignment="Center"/>

                        <!-- Add Source Flyout -->
                        <Button Grid.Column="1"
                                Content="+"
                                Background="#2a0028" Foreground="#c96cc0"
                                BorderThickness="0" Padding="10,4" CornerRadius="5"
                                FontSize="16" FontWeight="Bold" Cursor="Hand">
                            <Button.Flyout>
                                <Flyout Placement="Top">
                                    <StackPanel Width="240" Spacing="8" Margin="4">
                                        <TextBlock Text="AJOUTER UNE SOURCE"
                                                   FontSize="12" FontWeight="Bold" Foreground="#f0f0f0"/>
                                        <Rectangle Height="1" Fill="#1a4060"/>

                                        <TextBlock Text="Sources vidéo" Foreground="#6b7a8d"
                                                   FontSize="10" Margin="0,4,0,0"/>
                                        <Button Classes="source-type-btn" Content="Capture d'écran"
                                                Command="{Binding AddScreenCaptureCommand}"/>
                                        <Button Classes="source-type-btn" Content="Caméra"
                                                Command="{Binding AddCameraCommand}"/>
                                        <Button Classes="source-type-btn" Content="Capture de fenêtre"
                                                Command="{Binding AddWindowCaptureCommand}"/>

                                        <TextBlock Text="Sources audio" Foreground="#6b7a8d"
                                                   FontSize="10" Margin="0,4,0,0"/>
                                        <Button Classes="source-type-btn" Content="Audio système"
                                                Command="{Binding AddSystemAudioCommand}"/>
                                        <Button Classes="source-type-btn" Content="Microphone"
                                                Command="{Binding AddMicrophoneCommand}"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>

                    <Rectangle Grid.Row="1" Height="1" Fill="#0d3450"/>

                    <!-- Dynamic source list -->
                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding SelectedScene.Sources}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:SourceItem">
                                    <Border Background="#0a2540" CornerRadius="5" Padding="10,7" Margin="0,2">
                                        <Grid ColumnDefinitions="12, *, Auto, Auto">
                                            <Ellipse Grid.Column="0" Width="7" Height="7"
                                                     Fill="{Binding Color}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       Foreground="#d8dfe8" FontSize="12"
                                                       Margin="8,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Type}"
                                                       Foreground="#6b7a8d" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Button Grid.Column="3"
                                                    Content="✕"
                                                    Background="Transparent" Foreground="#4a5a6d"
                                                    BorderThickness="0" FontSize="11" Padding="4,2"
                                                    Cursor="Hand"
                                                    Command="{Binding $parent[UserControl].((vm:ScenesViewModel)DataContext).RemoveSourceCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>

    </Grid>

</UserControl>
