<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels"
             xmlns:m="using:Castor.Engine.Models"
             xmlns:engineModels="using:Castor.Engine.Models"
             xmlns:controls="using:CastorApplication.Controls"
             x:Class="CastorApplication.Views.ScenesView"
             x:Name="ScenesRoot"
             x:DataType="vm:ScenesViewModel">

    <UserControl.Styles>

        <Style Selector="Button.source-type-btn">
            <Setter Property="Background" Value="{DynamicResource AppSurface2}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg2}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.source-type-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppNavBadgeBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg1}"/>
        </Style>

        <Style Selector="Button.scene-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.scene-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppNavHoverBg}"/>
        </Style>

        <Style Selector="Button.scene-menu-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg2}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.scene-menu-item:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppSurface2}"/>
        </Style>

        <Style Selector="Button.scene-menu-item.danger">
            <Setter Property="Foreground" Value="#f87171"/>
        </Style>

        <Style Selector="Button.scene-toolbar-item, ToggleButton.scene-toolbar-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppFg3}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style Selector="Button.scene-toolbar-item:pointerover /template/ ContentPresenter,
                         ToggleButton.scene-toolbar-item:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppSurface2}"/>
        </Style>

        <Style Selector="ToggleButton.scene-toolbar-item:checked /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppAccentBg}"/>
        </Style>

        <Style Selector="ToggleButton.scene-toolbar-item:checked">
            <Setter Property="Foreground" Value="#5b8def"/>
        </Style>

        <Style Selector="Button.scene-toolbar-item.danger">
            <Setter Property="Foreground" Value="#f87171"/>
        </Style>

    </UserControl.Styles>

    <Grid ColumnDefinitions="240, 1, *" Background="{DynamicResource AppBg}">

        <!-- ═══ SCENES LIST ═══ -->
        <Border Grid.Column="0" Background="{DynamicResource AppSurface}">
            <Grid RowDefinitions="56, Auto, Auto, Auto, 1, *">

                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="14,0">
                    <TextBlock Grid.Column="0" Text="SCÈNES"
                               FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppFg4}"
                               VerticalAlignment="Center"/>

                    <!-- Create Scene Flyout -->
                    <Button Grid.Column="1"
                            Content="+"
                            Background="{DynamicResource AppAccentBg}" Foreground="#5b8def"
                            BorderThickness="0" Padding="10,4" CornerRadius="5"
                            FontSize="16" FontWeight="Bold"
                            VerticalAlignment="Center" Cursor="Hand">
                        <Button.Flyout>
                            <Flyout Placement="Right">
                                <StackPanel Width="260" Spacing="12" Margin="4">
                                    <TextBlock Text="NOUVELLE SCÈNE"
                                               FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AppFg1}"/>
                                    <Rectangle Height="1" Fill="{DynamicResource AppBorder2}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Nom de la scène" Foreground="{DynamicResource AppFg3}" FontSize="11"/>
                                        <TextBox Text="{Binding NewSceneName}"
                                                 Watermark="Ex: Match Live"
                                                 KeyDown="OnCreateSceneKeyDown"
                                                 Background="{DynamicResource AppSurface2}" BorderBrush="{DynamicResource AppBorder2}" Foreground="{DynamicResource AppFg2}"/>
                                    </StackPanel>
                                    <Button Content="CRÉER LA SCÈNE"
                                            Command="{Binding CreateSceneCommand}"
                                            Click="OnCloseFlyoutClick"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Height="36" Background="#5b8def" Foreground="#eaeaf0"
                                            BorderThickness="0" CornerRadius="6"
                                            FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>

                <!-- Toolbar: sort + fichier + selection mode -->
                <StackPanel Grid.Row="1" Margin="8,0,8,8" Spacing="1">

                    <Button Classes="scene-toolbar-item">
                        <Grid ColumnDefinitions="20, *, Auto">
                            <Viewbox Grid.Column="0" Width="16" Height="16"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M3 9l4 -4l4 4m-4 -4v14"
                                          Stroke="{DynamicResource AppFg4}" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                    <Path Data="M21 15l-4 4l-4 -4m4 4v-14"
                                          Stroke="{DynamicResource AppFg4}" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Trier" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="›" Foreground="{DynamicResource AppFg5}"/>
                        </Grid>
                        <Button.Flyout>
                            <Flyout Placement="RightEdgeAlignedTop">
                                <StackPanel Width="180" Spacing="2" Margin="4">
                                    <Button Classes="scene-menu-item" Content="Nom (A → Z)"
                                            Command="{Binding SortScenesCommand}" CommandParameter="name_asc"/>
                                    <Button Classes="scene-menu-item" Content="Nom (Z → A)"
                                            Command="{Binding SortScenesCommand}" CommandParameter="name_desc"/>
                                    <Button Classes="scene-menu-item" Content="Plus récentes d'abord"
                                            Command="{Binding SortScenesCommand}" CommandParameter="date_desc"/>
                                    <Button Classes="scene-menu-item" Content="Plus anciennes d'abord"
                                            Command="{Binding SortScenesCommand}" CommandParameter="date_asc"/>
                                    <Button Classes="scene-menu-item" Content="Couleur"
                                            Command="{Binding SortScenesCommand}" CommandParameter="color"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Classes="scene-toolbar-item">
                        <Grid ColumnDefinitions="20, *, Auto">
                            <Viewbox Grid.Column="0" Width="16" Height="16"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M5 4h4l3 3h7a2 2 0 0 1 2 2v8a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-11a2 2 0 0 1 2 -2"
                                          Stroke="{DynamicResource AppFg4}" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Fichier" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="›" Foreground="{DynamicResource AppFg5}"/>
                        </Grid>
                        <Button.Flyout>
                            <Flyout Placement="RightEdgeAlignedTop">
                                <StackPanel Width="180" Spacing="2" Margin="4">
                                    <Button Classes="scene-menu-item" Content="Exporter"
                                            Command="{Binding ExportScenesCommand}"/>
                                    <Button Classes="scene-menu-item" Content="Importer..."
                                            Command="{Binding ImportScenesCommand}"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <ToggleButton Classes="scene-toolbar-item"
                                  IsChecked="{Binding IsSelectionModeActive}">
                        <Grid ColumnDefinitions="20, *, Auto">
                            <Viewbox Grid.Column="0" Width="16" Height="16"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M9 11l3 3l8 -8"
                                          Stroke="{DynamicResource AppFg4}" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                    <Path Data="M20 12v6a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2h9"
                                          Stroke="{DynamicResource AppFg4}" StrokeThickness="2"
                                          StrokeLineCap="Round" StrokeJoin="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Sélectionner" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="✓" Foreground="#5b8def"
                                       IsVisible="{Binding IsSelectionModeActive}"/>
                        </Grid>
                    </ToggleButton>

                </StackPanel>

                <TextBlock Grid.Row="2" Text="{Binding SceneIoStatus}"
                           IsVisible="{Binding SceneIoStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Foreground="{DynamicResource AppFg3}" FontSize="10" TextWrapping="Wrap"
                           Margin="14,0,14,8"/>

                <!-- Bulk actions bar -->
                <StackPanel Grid.Row="3" Margin="8,6" Spacing="1"
                            IsVisible="{Binding IsSelectionModeActive}">

                    <TextBlock Text="{Binding DeleteSceneError}"
                               IsVisible="{Binding DeleteSceneError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                               Foreground="#f87171" FontSize="10" TextWrapping="Wrap"
                               Margin="10,0,10,6"/>

                    <Button Classes="scene-toolbar-item">
                        <Grid ColumnDefinitions="20, *, Auto">
                            <Ellipse Grid.Column="0" Width="12" Height="12" Fill="#5b8def"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Couleur de la sélection" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="›" Foreground="{DynamicResource AppFg5}"/>
                        </Grid>
                        <Button.Flyout>
                            <Flyout Placement="RightEdgeAlignedTop">
                                <StackPanel Width="200" Spacing="8" Margin="4">
                                    <TextBlock Text="COULEUR DE LA SÉLECTION"
                                               FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AppFg1}"/>
                                    <ItemsControl ItemsSource="{x:Static vm:ScenesViewModel.SceneColorPalette}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Button Width="24" Height="24" CornerRadius="12" Margin="3"
                                                        Background="{Binding}"
                                                        BorderThickness="1" BorderBrush="{DynamicResource AppBorder2}"
                                                        Padding="0" Cursor="Hand"
                                                        Command="{Binding #ScenesRoot.DataContext.AssignColorToSelectionCommand}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button Classes="scene-toolbar-item"
                            Command="{Binding StartSelectedFileScenesTogetherCommand}"
                            ToolTip.Tip="Démarre en même temps les scènes sélectionnées qui contiennent une source fichier">
                        <Grid ColumnDefinitions="20, *">
                            <TextBlock Grid.Column="0" Text="▶" FontSize="10" Foreground="{DynamicResource AppFg4}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Démarrer ensemble" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Classes="scene-toolbar-item danger"
                            Command="{Binding DeleteSelectedScenesCommand}">
                        <Grid ColumnDefinitions="20, *">
                            <TextBlock Grid.Column="0" Text="✕" FontSize="11" Foreground="#f87171"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Supprimer la sélection" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                </StackPanel>

                <Rectangle Grid.Row="4" Fill="{DynamicResource AppBorder}"/>

                <!-- Dynamic scene list -->
                <ScrollViewer Grid.Row="5">
                    <ItemsControl ItemsSource="{Binding Scenes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:SceneItem">
                                <Grid ColumnDefinitions="Auto, Auto, *, Auto"
                                      DragDrop.AllowDrop="True"
                                      DragDrop.DragOver="OnSceneRowDragOver"
                                      DragDrop.Drop="OnSceneRowDrop">

                                    <CheckBox Grid.Column="0"
                                              IsVisible="{Binding #ScenesRoot.DataContext.IsSelectionModeActive}"
                                              IsChecked="{Binding IsMultiSelected}"
                                              VerticalAlignment="Center" Margin="10,0,0,0"/>

                                    <Border Grid.Column="1" Width="22"
                                            Background="Transparent" Cursor="SizeAll"
                                            ToolTip.Tip="Glisser pour réordonner"
                                            PointerPressed="OnSceneDragHandlePointerPressed">
                                        <TextBlock Text="⠿" FontSize="14"
                                                   Foreground="{DynamicResource AppFg5}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Button Grid.Column="2" Classes="scene-btn"
                                            Command="{Binding #ScenesRoot.DataContext.SelectSceneCommand}"
                                            CommandParameter="{Binding}">
                                        <Panel>
                                            <!-- Active scene display -->
                                            <Border IsVisible="{Binding IsActive}"
                                                    Background="{DynamicResource AppAccentBg2}"
                                                    BorderBrush="#5b8def"
                                                    BorderThickness="3,0,0,0">
                                                <Grid ColumnDefinitions="*, Auto" Margin="14,10,10,10">
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                        <Ellipse Width="8" Height="8" Fill="{Binding Color}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="▶" Foreground="#5b8def" FontSize="10"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AppFg1}"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="1"
                                                            IsVisible="{Binding IsLive}"
                                                            Background="#5b8def" CornerRadius="3" Padding="6,2">
                                                        <TextBlock Text="EN DIRECT" Foreground="#eaeaf0"
                                                                   FontSize="9" FontWeight="Bold"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Inactive scene display -->
                                            <Border IsVisible="{Binding !IsActive}"
                                                    Padding="14,10">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Ellipse Width="8" Height="8" Fill="{Binding Color}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{DynamicResource AppFg3}" FontSize="13"/>
                                                </StackPanel>
                                            </Border>
                                        </Panel>
                                    </Button>

                                    <!-- Actions -->
                                    <Button Grid.Column="3"
                                            Content="⋮"
                                            Background="Transparent" Foreground="{DynamicResource AppFg5}"
                                            BorderThickness="0" FontSize="16" FontWeight="Bold" Padding="8,4"
                                            Cursor="Hand"
                                            ToolTip.Tip="Actions">
                                        <Button.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedRight">
                                                <StackPanel Width="150" Spacing="2" Margin="4">

                                                    <Button Classes="scene-menu-item" Content="Renommer"
                                                            Command="{Binding #ScenesRoot.DataContext.BeginRenameSceneCommand}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Flyout>
                                                            <Flyout Placement="Right">
                                                                <StackPanel Width="220" Spacing="10" Margin="4">
                                                                    <TextBlock Text="RENOMMER LA SCÈNE"
                                                                               FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AppFg1}"/>
                                                                    <TextBox Text="{Binding #ScenesRoot.DataContext.RenameSceneName}"
                                                                             KeyDown="OnRenameSceneKeyDown"
                                                                             Background="{DynamicResource AppSurface2}"
                                                                             BorderBrush="{DynamicResource AppBorder2}"
                                                                             Foreground="{DynamicResource AppFg2}"/>
                                                                    <Button Content="RENOMMER"
                                                                            Command="{Binding #ScenesRoot.DataContext.ConfirmRenameSceneCommand}"
                                                                            Click="OnCloseFlyoutClick"
                                                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                            Height="32" Background="#5b8def" Foreground="#eaeaf0"
                                                                            BorderThickness="0" CornerRadius="6"
                                                                            FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                                                                </StackPanel>
                                                            </Flyout>
                                                        </Button.Flyout>
                                                    </Button>

                                                    <Button Classes="scene-menu-item" Content="Couleur"
                                                            Command="{Binding #ScenesRoot.DataContext.BeginAssignColorCommand}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Flyout>
                                                            <Flyout Placement="Right">
                                                                <StackPanel Width="200" Spacing="8" Margin="4">
                                                                    <TextBlock Text="COULEUR DE LA SCÈNE"
                                                                               FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AppFg1}"/>
                                                                    <ItemsControl ItemsSource="{x:Static vm:ScenesViewModel.SceneColorPalette}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <WrapPanel/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="x:String">
                                                                                <Button Width="24" Height="24" CornerRadius="12" Margin="3"
                                                                                        Background="{Binding}"
                                                                                        BorderThickness="1" BorderBrush="{DynamicResource AppBorder2}"
                                                                                        Padding="0" Cursor="Hand"
                                                                                        Command="{Binding #ScenesRoot.DataContext.AssignSceneColorCommand}"
                                                                                        CommandParameter="{Binding}"/>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Flyout>
                                                        </Button.Flyout>
                                                    </Button>

                                                    <Rectangle Height="1" Fill="{DynamicResource AppBorder2}" Margin="4,2"/>

                                                    <Button Classes="scene-menu-item danger" Content="Supprimer">
                                                        <Button.Flyout>
                                                            <Flyout Placement="Right">
                                                                <StackPanel Width="200" Spacing="10" Margin="4">
                                                                    <TextBlock Text="Supprimer cette scène ?"
                                                                               TextWrapping="Wrap"
                                                                               FontSize="12" Foreground="{DynamicResource AppFg1}"/>
                                                                    <TextBlock Text="{Binding #ScenesRoot.DataContext.DeleteSceneError}"
                                                                               IsVisible="{Binding #ScenesRoot.DataContext.DeleteSceneError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                               Foreground="#f87171" FontSize="10" TextWrapping="Wrap"/>
                                                                    <Button Content="SUPPRIMER"
                                                                            Command="{Binding #ScenesRoot.DataContext.DeleteSceneCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                                            Height="32" Background="#f87171" Foreground="#eaeaf0"
                                                                            BorderThickness="0" CornerRadius="6"
                                                                            FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                                                                </StackPanel>
                                                            </Flyout>
                                                        </Button.Flyout>
                                                    </Button>

                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Border>

        <Rectangle Grid.Column="1" Fill="{DynamicResource AppBorder}"/>

        <!-- ═══ RIGHT PANEL ═══ -->
        <Grid Grid.Column="2" RowDefinitions="*, 8, 200" Margin="8">

            <!-- Scene preview -->
            <Border Grid.Row="0"
                    Background="Black" CornerRadius="8"
                    BorderBrush="{DynamicResource AppBorder}" BorderThickness="1"
                    ClipToBounds="True">
                <Panel>
                    <controls:DirectXPreviewView Scene="{Binding SelectedScene}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"/>

                    <!-- Placeholder quand aucune scène n'est sélectionnée -->
                    <TextBlock Text="APERÇU DE LA SCÈNE"
                               IsVisible="{Binding SelectedScene, Converter={x:Static ObjectConverters.IsNull}}"
                               Foreground="{DynamicResource AppSurface2}" HorizontalAlignment="Center"
                               VerticalAlignment="Center" FontSize="18" FontWeight="Bold"/>

                    <!-- Nom de la scène en overlay -->
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                            Margin="12" Padding="10,6" CornerRadius="5"
                            IsVisible="{Binding SelectedScene, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Background="#AA0B0B12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                        <TextBlock Text="{Binding SelectedScene.Name}"
                                   Foreground="{DynamicResource AppFg3}" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </Panel>
            </Border>

            <Rectangle Grid.Row="1" Fill="Transparent"/>

            <!-- Sources of selected scene -->
            <Border Grid.Row="2" Background="{DynamicResource AppSurface}" CornerRadius="8" Padding="14">
                <Grid RowDefinitions="Auto, 10, *">

                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                        <TextBlock Grid.Column="0" Text="SOURCES DE LA SCÈNE"
                                   FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppFg4}"
                                   VerticalAlignment="Center"/>

                        <!-- Ouvre le dialogue « Ajouter une source » -->
                        <Button Grid.Column="1"
                                Content="+"
                                Click="OnAddSourceClick"
                                Background="{DynamicResource AppAccentBg}" Foreground="#5b8def"
                                BorderThickness="0" Padding="10,4" CornerRadius="5"
                                FontSize="16" FontWeight="Bold" Cursor="Hand"
                                ToolTip.Tip="Ajouter une source"/>
                    </Grid>

                    <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource AppBorder}"/>

                    <!-- Dynamic source list -->
                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding SelectedScene.Sources}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:SourceItem">
                                    <Border Background="{DynamicResource AppSurface2}" CornerRadius="5" Padding="10,7" Margin="0,2">
                                        <Grid ColumnDefinitions="12, *, Auto, Auto, Auto">
                                            <Ellipse Grid.Column="0" Width="7" Height="7"
                                                     Fill="{Binding Color}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       Foreground="{DynamicResource AppFg2}" FontSize="12"
                                                       Margin="8,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Type}"
                                                       Foreground="{DynamicResource AppFg4}" FontSize="10"
                                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <!-- Bouton boucle — visible uniquement pour les sources fichier -->
                                            <ToggleButton Grid.Column="3"
                                                          IsVisible="{Binding IsFileSource}"
                                                          IsChecked="{Binding Loop}"
                                                          ToolTip.Tip="Boucle automatique"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="4,2" Cursor="Hand"
                                                          FontSize="12">
                                                <ToggleButton.Styles>
                                                    <Style Selector="ToggleButton:checked /template/ ContentPresenter">
                                                        <Setter Property="Foreground" Value="#a78bfa"/>
                                                    </Style>
                                                    <Style Selector="ToggleButton:unchecked /template/ ContentPresenter">
                                                        <Setter Property="Foreground" Value="{DynamicResource AppFg5}"/>
                                                    </Style>
                                                </ToggleButton.Styles>
                                                <TextBlock Text="⟳" FontSize="14"/>
                                            </ToggleButton>
                                            <Button Grid.Column="4"
                                                    Content="✕"
                                                    Background="Transparent" Foreground="{DynamicResource AppFg5}"
                                                    BorderThickness="0" FontSize="11" Padding="4,2"
                                                    Cursor="Hand"
                                                    Command="{Binding #ScenesRoot.DataContext.RemoveSourceCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>

    </Grid>

</UserControl>
