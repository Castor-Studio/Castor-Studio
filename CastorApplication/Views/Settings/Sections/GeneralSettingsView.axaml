<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels.Settings.Sections"
             x:Class="CastorApplication.Views.Settings.Sections.GeneralSettingsView"
             x:DataType="vm:GeneralSettingsViewModel">

    <StackPanel Margin="28,20"
                Spacing="28">

        <StackPanel Spacing="14">

            <TextBlock Text="GÉNÉRAL"
                       Classes="section-title"/>

            <Grid ColumnDefinitions="180,*">
                <TextBlock Grid.Column="0"
                           Text="Thème"
                           Classes="setting-label"/>

                <ComboBox Grid.Column="1"
                          MaxWidth="260"
                          HorizontalAlignment="Left"
                          SelectedIndex="{Binding SelectedThemeIndex}">

                    <ComboBoxItem Content="Sombre"/>
                    <ComboBoxItem Content="Clair"/>

                </ComboBox>
            </Grid>

            <Rectangle Height="1"
                       Fill="{DynamicResource AppBorder}"
                       Margin="0,4"/>

            <Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,14">

                <Grid ColumnDefinitions="*,Auto">

                    <StackPanel Grid.Column="0"
                                Spacing="4">

                        <TextBlock Text="Castor Studio"
                                   Foreground="{DynamicResource AppFg1}"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Libérez le flot de vos événements"
                                   Foreground="{DynamicResource AppFg4}"
                                   FontSize="11"
                                   FontStyle="Italic"/>
                    </StackPanel>

                </Grid>

            </Border>

        </StackPanel>

    </StackPanel>

</UserControl>