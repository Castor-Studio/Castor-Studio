<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CastorApplication.ViewModels.Settings.Sections"
             x:Class="CastorApplication.Views.Settings.Sections.AccountsSettingsView"
             x:DataType="vm:AccountsSettingsViewModel">

    <StackPanel Margin="28,20"
                Spacing="28">

        <StackPanel Spacing="14">

            <TextBlock Text="COMPTES"
                       Classes="section-title"/>

            <TextBlock Text="Connectez vos comptes de streaming pour diffuser directement depuis Castor."
                       Foreground="{DynamicResource AppFg4}"
                       FontSize="12"
                       Margin="0,0,0,4"/>

            <!-- Twitch -->
            <Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">

                <Grid ColumnDefinitions="Auto,*,Auto">

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="12">

                        <Border CornerRadius="6"
                                Width="36"
                                Height="36"
                                ClipToBounds="True">

                            <Image Source="avares://CastorApplication/Assets/twitch-logo.png"
                                   Width="36"
                                   Height="36"
                                   Stretch="UniformToFill"/>

                        </Border>

                        <StackPanel VerticalAlignment="Center">

                            <TextBlock Text="Twitch"
                                       Foreground="{DynamicResource AppFg1}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="{Binding TwitchStatus}"
                                       Foreground="{DynamicResource AppFg4}"
                                       FontSize="11"/>

                        </StackPanel>

                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="{Binding TwitchButtonText}"
                            Classes="platform-connect"
                            Command="{Binding ConnectTwitchCommand}"/>

                </Grid>

            </Border>

            <!-- YouTube -->
            <!--<Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">

                <Grid ColumnDefinitions="Auto,*,Auto">

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="12">

                        <Border CornerRadius="6"
                                Width="36"
                                Height="36"
                                ClipToBounds="True">

                            <Image Source="avares://CastorApplication/Assets/youtube-logo.png"
                                   Width="36"
                                   Height="36"
                                   Stretch="UniformToFill"/>

                        </Border>

                        <StackPanel VerticalAlignment="Center">

                            <TextBlock Text="YouTube Live"
                                       Foreground="{DynamicResource AppFg1}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="{Binding YoutubeStatus}"
                                       Foreground="{DynamicResource AppFg4}"
                                       FontSize="11"/>

                        </StackPanel>

                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="{Binding YoutubeButtonText}"
                            Classes="platform-connect"
                            Command="{Binding ToggleYoutubeCommand}"/>

                </Grid>

            </Border>-->

            <!-- Facebook -->
            <!--<Border Background="{DynamicResource AppSurface}"
                    BorderBrush="{DynamicResource AppBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">

                <Grid ColumnDefinitions="Auto,*,Auto">

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="12">

                        <Border CornerRadius="6"
                                Width="36"
                                Height="36"
                                ClipToBounds="True">

                            <Image Source="avares://CastorApplication/Assets/facebook-logo.png"
                                   Width="36"
                                   Height="36"
                                   Stretch="UniformToFill"/>

                        </Border>

                        <StackPanel VerticalAlignment="Center">

                            <TextBlock Text="Facebook Live"
                                       Foreground="{DynamicResource AppFg1}"
                                       FontSize="13"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="{Binding FacebookStatus}"
                                       Foreground="{DynamicResource AppFg4}"
                                       FontSize="11"/>

                        </StackPanel>

                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="{Binding FacebookButtonText}"
                            Classes="platform-connect"
                            Command="{Binding ToggleFacebookCommand}"/>

                </Grid>

            </Border>-->

        </StackPanel>

    </StackPanel>

</UserControl>