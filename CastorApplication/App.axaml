<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CastorApplication.App"
             xmlns:local="using:CastorApplication"
             xmlns:vm="using:CastorApplication.ViewModels"
             xmlns:m="using:Castor.Engine.Models"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>

        <!-- ── PREVIEW VIDÉO ── -->
        <DataTemplate x:DataType="vm:StudioViewModel">
            <Panel Background="{DynamicResource AppSurface3}">
                <TextBlock Text="APERÇU VIDÉO"
                           Foreground="{DynamicResource AppSurface2}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="22" FontWeight="Bold" LetterSpacing="3"/>
                <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                        Margin="10" Padding="8,4" CornerRadius="4"
                        Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Ellipse Width="7" Height="7" Fill="{Binding StreamStatusBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StreamStatusText}"
                                   Foreground="{Binding StreamStatusBrush}"
                                   FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Left"
                           Margin="14,0,0,12" Text="00:00:00"
                           Foreground="{Binding StreamTimerBrush}"
                           FontSize="16" FontFamily="Courier New"/>
            </Panel>
        </DataTemplate>

        <!-- ── SOURCES ── -->
        <DataTemplate x:DataType="vm:SourcesPanelContext">
            <Grid RowDefinitions="*, Auto" Margin="8,6">
                <ListBox Grid.Row="0"
                         ItemsSource="{Binding Studio.Sources}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="4,3"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:SourceItem">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Ellipse Grid.Column="0" Width="7" Height="7"
                                         Fill="{Binding Color}"
                                         VerticalAlignment="Center" Margin="0,0,7,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           Foreground="{DynamicResource AppFg2}" FontSize="12"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2" Text="{Binding Type}"
                                           Foreground="{DynamicResource AppFg4}" FontSize="10"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Grid.Row="1"
                        Content="+ Ajouter une source"
                        Command="{Binding Studio.AddSourceCommand}"
                        Height="28" FontSize="11"
                        Background="{DynamicResource AppSurface2}" Foreground="{DynamicResource AppFg3}"
                        BorderBrush="{DynamicResource AppBorder2}" BorderThickness="1"
                        CornerRadius="5" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,4,0,0" Cursor="Hand"/>
            </Grid>
        </DataTemplate>

        <!-- ── MIXER AUDIO ── -->
        <DataTemplate x:DataType="vm:AudioPanelContext">
            <StackPanel VerticalAlignment="Center" Spacing="10" Margin="10,8">
                <Grid ColumnDefinitions="56, *, 38">
                    <TextBlock Grid.Column="0" Text="Bureau"
                               Foreground="{DynamicResource AppFg3}" FontSize="11" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="100"
                            Value="{Binding Studio.DesktopVolume}" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding Studio.DesktopVolumeDisplay}"
                               Foreground="{DynamicResource AppFg2}" FontSize="11"
                               VerticalAlignment="Center" TextAlignment="Right"/>
                </Grid>
                <Grid ColumnDefinitions="56, *, 38">
                    <TextBlock Grid.Column="0" Text="Micro"
                               Foreground="{DynamicResource AppFg3}" FontSize="11" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="100"
                            Value="{Binding Studio.MicVolume}" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding Studio.MicVolumeDisplay}"
                               Foreground="{DynamicResource AppFg2}" FontSize="11"
                               VerticalAlignment="Center" TextAlignment="Right"/>
                </Grid>
                <Grid ColumnDefinitions="56, *, 38">
                    <TextBlock Grid.Column="0" Text="Musique"
                               Foreground="{DynamicResource AppFg3}" FontSize="11" VerticalAlignment="Center"/>
                    <Slider Grid.Column="1" Minimum="0" Maximum="100"
                            Value="{Binding Studio.MusicVolume}" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding Studio.MusicVolumeDisplay}"
                               Foreground="{DynamicResource AppFg2}" FontSize="11"
                               VerticalAlignment="Center" TextAlignment="Right"/>
                </Grid>
            </StackPanel>
        </DataTemplate>

    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>

                <!-- ═══ THÈME SOMBRE ═══ -->
                <ResourceDictionary x:Key="Dark">
                    <!-- Fonds -->
                    <SolidColorBrush x:Key="AppBg"          Color="#0b0b12"/>
                    <SolidColorBrush x:Key="AppSurface"     Color="#13131c"/>
                    <SolidColorBrush x:Key="AppSurface2"    Color="#1c1c28"/>
                    <SolidColorBrush x:Key="AppSurface3"    Color="#09090f"/>
                    <SolidColorBrush x:Key="AppVeryDarkBg"  Color="#07070d"/>
                    <SolidColorBrush x:Key="AppNavBadgeBg"  Color="#24242f"/>
                    <SolidColorBrush x:Key="AppBadgeBg"     Color="#24242f"/>
                    <SolidColorBrush x:Key="AppNavHoverBg"  Color="#1c1c28"/>
                    <SolidColorBrush x:Key="AppAccentBg"    Color="#162040"/>
                    <SolidColorBrush x:Key="AppAccentBg2"   Color="#141c30"/>
                    <!-- Bordures -->
                    <SolidColorBrush x:Key="AppBorder"      Color="#2a2a38"/>
                    <SolidColorBrush x:Key="AppBorder2"     Color="#36364a"/>
                    <!-- Textes -->
                    <SolidColorBrush x:Key="AppFg1"         Color="#eaeaf0"/>
                    <SolidColorBrush x:Key="AppFg2"         Color="#ccccd8"/>
                    <SolidColorBrush x:Key="AppFg3"         Color="#8888a0"/>
                    <SolidColorBrush x:Key="AppFg4"         Color="#5c5c72"/>
                    <SolidColorBrush x:Key="AppFg5"         Color="#3c3c4e"/>
                    <SolidColorBrush x:Key="AppFg6"         Color="#36364a"/>
                    <!-- Boutons d'action -->
                    <SolidColorBrush x:Key="AppLiveBg"      Color="#0e2420"/>
                    <SolidColorBrush x:Key="AppLiveBorder"  Color="#142e25"/>
                    <SolidColorBrush x:Key="AppStopBg"      Color="#251218"/>
                    <SolidColorBrush x:Key="AppStopBorder"  Color="#2f1820"/>
                    <SolidColorBrush x:Key="AppRecBg"       Color="#2d1212"/>
                    <SolidColorBrush x:Key="AppRecBorder"   Color="#3d1a1a"/>
                </ResourceDictionary>

                <!-- ═══ THÈME CLAIR ═══ -->
                <ResourceDictionary x:Key="Light">
                    <!-- Fonds — blanc cassé avec teinte bleue/grise subtile -->
                    <SolidColorBrush x:Key="AppBg"          Color="#eeeef6"/>
                    <SolidColorBrush x:Key="AppSurface"     Color="#f6f6fc"/>
                    <SolidColorBrush x:Key="AppSurface2"    Color="#eaeaf4"/>
                    <SolidColorBrush x:Key="AppSurface3"    Color="#e2e2ee"/>
                    <SolidColorBrush x:Key="AppVeryDarkBg"  Color="#d4d4e8"/>
                    <SolidColorBrush x:Key="AppNavBadgeBg"  Color="#2a2a3a"/>
                    <SolidColorBrush x:Key="AppBadgeBg"     Color="#dcdcee"/>
                    <SolidColorBrush x:Key="AppNavHoverBg"  Color="#e0e0f0"/>
                    <SolidColorBrush x:Key="AppAccentBg"    Color="#dce8ff"/>
                    <SolidColorBrush x:Key="AppAccentBg2"   Color="#e2ebff"/>
                    <!-- Bordures -->
                    <SolidColorBrush x:Key="AppBorder"      Color="#ccccde"/>
                    <SolidColorBrush x:Key="AppBorder2"     Color="#bcbcd2"/>
                    <!-- Textes -->
                    <SolidColorBrush x:Key="AppFg1"         Color="#18182a"/>
                    <SolidColorBrush x:Key="AppFg2"         Color="#282844"/>
                    <SolidColorBrush x:Key="AppFg3"         Color="#484888"/>
                    <SolidColorBrush x:Key="AppFg4"         Color="#6868a0"/>
                    <SolidColorBrush x:Key="AppFg5"         Color="#8888b8"/>
                    <SolidColorBrush x:Key="AppFg6"         Color="#a0a0c0"/>
                    <!-- Boutons d'action -->
                    <SolidColorBrush x:Key="AppLiveBg"      Color="#d0f5e8"/>
                    <SolidColorBrush x:Key="AppLiveBorder"  Color="#6ee7b7"/>
                    <SolidColorBrush x:Key="AppStopBg"      Color="#fce8e8"/>
                    <SolidColorBrush x:Key="AppStopBorder"  Color="#f0a0a0"/>
                    <SolidColorBrush x:Key="AppRecBg"       Color="#fce8e8"/>
                    <SolidColorBrush x:Key="AppRecBorder"   Color="#f0a0a0"/>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
		<FluentTheme /> 
        <StyleInclude Source="avares://CastorApplication/Styles/SettingsStyles.axaml"/>
    </Application.Styles>
</Application>
